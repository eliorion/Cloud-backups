# ============================================================================
# TEMPLATE — PLAINTEXT PLACEHOLDERS, NOT ENCRYPTED. Do NOT commit real values.
# ============================================================================
# Copy to garage-fleet/secrets/common.sops.yaml, fill with the values printed
# by gen-secrets.sh, then `sops -e -i common.sops.yaml` to encrypt in place.
# The real common.sops.yaml is gitignored-by-convention as an encrypted file;
# only this .example lives in git with placeholders.
#
# The rpc/admin/metrics secrets are SHARED, identical, across all four nodes
# (doc 09 §3, doc 10 Phase 0). modules/sops.nix declares each as a sops.secrets.*
# entry and modules/garage.nix points garage.toml's *_file keys at the decrypted
# paths.
#
# ⚠️ rpc_secret is cluster-admin-equivalent for Garage: anyone holding it plus
#    RPC reach can join the gossip cluster (doc 09 §3). It is also break-glass.

# Garage cluster RPC secret — 32-byte hex. MUST be identical on every node or
# the gossip cluster will not form. `openssl rand -hex 32`.
rpc_secret: "TODO_operator_openssl_rand_hex_32_REPLACE_ME"

# Garage admin API token (gates the layout/key/bucket control plane on :3903).
# `openssl rand -hex 32`.
admin_token: "TODO_operator_openssl_rand_hex_32_REPLACE_ME"

# Garage Prometheus /metrics token. Without it /metrics is UNAUTHENTICATED
# (doc 09 §5/§9). `openssl rand -hex 32`.
metrics_token: "TODO_operator_openssl_rand_hex_32_REPLACE_ME"

# ZFS dataset passphrase for bpool/garage (STORAGE nodes A/B/C only — the
# gateway node-D has no encrypted data pool). modules/sops.nix declares
# `zfs-passphrase` (owner root, mode 0400) and the operator wires a boot-time
# `zfs load-key` from its decrypted path so the node reboot-unlocks WITHOUT the
# /tmp install seed (hosts/disko-storage.nix KEY PERSISTENCE note).
#
# ⚠️ CATASTROPHIC-LOSS + break-glass (doc 09 §8): decryptable only by the node's
#    age key, so a lost node fleet = unrecoverable raw-send vault. Keep an OFFLINE
#    copy in two physical locations. Use a strong random passphrase.
#    `openssl rand -base64 32`. (Putting it here shares ONE passphrase across
#    storage nodes — fine since each node can decrypt it. For a DISTINCT
#    per-node passphrase, move this key into a per-node *.sops.yaml and set
#    sopsFile per host in hosts/node-*.nix, like the tailscale auth key.)
zfs-passphrase: "TODO_operator_openssl_rand_base64_32_REPLACE_ME"
