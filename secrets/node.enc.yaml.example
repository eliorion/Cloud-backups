# ============================================================================
# TEMPLATE — PLAINTEXT PLACEHOLDER, NOT ENCRYPTED. Do NOT commit a real key.
# ============================================================================
# Copy to garage-fleet/secrets/<node>.enc.yaml (one per node:
# node-a/-b/-c/-d), paste the minted auth key, then `sops -e -i` to encrypt.
# modules/sops.nix declares sops.secrets."tailscale-authkey" from this file and
# modules/tailscale.nix uses it as services.tailscale.authKeyFile.
#
# Mint the key in the Tailscale admin console as: reusable, non-ephemeral,
# tagged tag:garage, long/no expiry (doc 09 §8, doc 10 Phase 0).
#
# ⚠️ This reusable tag:garage key is a CLUSTER-JOIN CREDENTIAL — anyone who
#    exfiltrates it can join a rogue device as tag:garage and attempt RPC
#    peering (blast radius = the whole gossip cluster). On suspected leak,
#    revoke it in the Tailscale admin console and re-mint (existing devices keep
#    their own node keys, so revocation does not strand them). Prefer one file
#    (one key) PER NODE over a single shared reusable key (doc 09 §8).

# Tailscale pre-auth key. Format: tskey-auth-XXXXXXXXXXXX-…
authkey: "tskey-auth-TODO_operator_paste_minted_tag_garage_authkey"

# --- console rescue password (PER NODE — do not reuse across nodes) ----------
# `root_password_hash` is what NixOS consumes (modules/base.nix
# users.users.root.hashedPasswordFile). Generate with:
#     nix develop -c openssl passwd -6
#
# `root_password` is the SAME password in the clear, kept only so you can look it
# up when you have forgotten it and the box is on a console at 3am. sops-nix does
# NOT read it — only declared secrets are extracted — but the whole file is
# encrypted to this node + the workstation, so it is no more exposed than the
# authkey above. Drop the line if you would rather rotate than recall (generate a
# new hash, `sops edit`, redeploy — no reinstall needed).
root_password: "TODO_operator_the_same_password_in_clear"
root_password_hash: "$6$TODO_operator_paste_openssl_passwd_-6_output"

# --- ZFS dataset passphrase — ONLY if fleet.zfsAutoUnlock = true -------------
# Node-specific by nature, hence this file rather than common.enc.yaml. Every
# node currently prompt-unlocks (zfsAutoUnlock = false), so modules/sops.nix
# declares this secret conditionally and it is UNUSED — omit the key entirely
# unless you flip that node to auto-unlock. Auto-unlock means the passphrase
# lives on the box, so a stolen box is NOT locked (doc 09 §7).
#zfs-passphrase: "TODO_operator_only_if_zfsAutoUnlock_true"
