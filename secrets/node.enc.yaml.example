# ============================================================================
# TEMPLATE — PLAINTEXT PLACEHOLDER, NOT ENCRYPTED. Do NOT commit a real key.
# ============================================================================
# Copy to garage-fleet/secrets/<node>.enc.yaml (one per node:
# node-a/-b/-c/-d), paste the minted auth key, then `sops -e -i` to encrypt.
# modules/sops.nix declares sops.secrets."tailscale-authkey" from this file and
# modules/tailscale.nix uses it as services.tailscale.authKeyFile.
#
# Mint the key in the Tailscale admin console as: reusable, non-ephemeral,
# tagged tag:garage, long/no expiry (doc 09 §8, doc 10 Phase 0).
#
# ⚠️ This reusable tag:garage key is a CLUSTER-JOIN CREDENTIAL — anyone who
#    exfiltrates it can join a rogue device as tag:garage and attempt RPC
#    peering (blast radius = the whole gossip cluster). On suspected leak,
#    revoke it in the Tailscale admin console and re-mint (existing devices keep
#    their own node keys, so revocation does not strand them). Prefer one file
#    (one key) PER NODE over a single shared reusable key (doc 09 §8).

# Tailscale pre-auth key. Format: tskey-auth-XXXXXXXXXXXX-…
authkey: "tskey-auth-TODO_operator_paste_minted_tag_garage_authkey"

# --- console rescue password (PER NODE — never reuse across nodes) -----------
# The HASH only. Generate with `nix develop -c openssl passwd -6`; keep the
# plaintext in the password manager (KeePass), never here.
#
# Why the hash is safe on the box but the ZFS passphrase is not: this file ships
# to the node (it is in the flake source) and the node CAN decrypt it — its age
# key is derived from /etc/ssh/ssh_host_ed25519_key on the UNENCRYPTED root. So
# assume anyone holding the box can read every value in here. A password hash
# costs them nothing: with the hardware they can already boot a USB stick, mount
# the unencrypted root and take what they want — the root password only guards a
# RUNNING, still-trusted box. The ZFS passphrase is the opposite: it is the one
# asset possession does NOT hand over, so it must never appear in this file
# (see the note at the bottom).
#
# Use a UNIQUE random password per node. Reuse is the real risk: node-A runs
# arbitrary devcontainer code as effective root (modules/workstation.nix), so a
# password shared with anything else leaks from your most exposed box.
root_password_hash: "$6$TODO_operator_paste_openssl_passwd_-6_output"

# --- NOT here: zfs-passphrase ------------------------------------------------
# Never put it in this file, even though modules/sops.nix would read it when
# fleet.zfsAutoUnlock = true. This file ships to the node and the node can
# decrypt it, so storing the passphrase here closes the loop:
#   unencrypted root -> ssh host key -> ssh-to-age -> age key -> decrypt this
#   file -> zfs-passphrase -> zfs load-key
# i.e. a stolen box unlocks its own backups and the encryption bought nothing —
# while you still type the passphrase at every reboot. Worst of both.
# Keep it OFFLINE ONLY (password manager + a second physical copy, doc 09 §8);
# it is typed at `fleet install` and at each post-boot unlock. There is NO
# recovery path if it is lost: keylocation=prompt has no backdoor.
