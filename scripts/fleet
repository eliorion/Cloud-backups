# pool, no moat). Scaffolded by scripts/fleet.
{ ... }:
{
  imports = [
    ./disko-@NODE@.nix
    ./@NODE@-hardware.nix
  ];

  networking.hostName = "@NODE@";
  networking.hostId = "@HOSTID@"; # unique 8-hex (auto-generated)

  fleet = {
    role = "gateway";
    zone = null; # gateway has NO zone
    proxyNode = false;
    tailscaleIp = "@TSIP@"; # TODO operator: set after first tailscale join
  };

}
EOF
}
disko_template_A() { cat <<'EOF'
# hosts/disko-@NODE@.nix — TYPE A. NVMe: ESP + ext4 root + UNENCRYPTED wpool
# (dev/podman home). HDD: encrypted dpool = all Garage. Scaffolded by scripts/fleet.
# ⚠️ DESTROYS both disks. Confirm device paths with `lsblk` on the box first.
{ config, ... }:
let
  garageKeylocation =
    if config.fleet.zfsInstallKeyfile != null then "file://${config.fleet.zfsInstallKeyfile}" else "prompt";
in
{
  disko.devices = {
    disk = {
      nvme = {
        type = "disk";
        device = "/dev/nvme0n1"; # TODO operator: confirm with `lsblk`
        content = {
          type = "gpt";
          partitions = {
            ESP = { type = "EF00"; size = "512M"; content = { type = "filesystem"; format = "vfat"; mountpoint = "/boot"; mountOptions = [ "umask=0077" ]; }; };
            root = { size = "60G"; content = { type = "filesystem"; format = "ext4"; mountpoint = "/"; }; };
            zfs = { size = "100%"; content = { type = "zfs"; pool = "wpool"; }; };
          };
        };
      };
      hdd = { type = "disk"; device = "/dev/sda"; content = { type = "zfs"; pool = "dpool"; }; }; # TODO device
    };
    zpool = {
      wpool = {
        type = "zpool"; mode = "";
        rootFsOptions = { compression = "zstd"; "com.sun:auto-snapshot" = "false"; acltype = "posixacl"; xattr = "sa"; };
        options.ashift = "12";
        datasets."dev" = { type = "zfs_fs"; mountpoint = "/home/dev"; };
      };
      dpool = {
        type = "zpool"; mode = "";
        rootFsOptions = { compression = "zstd"; "com.sun:auto-snapshot" = "false"; acltype = "posixacl"; xattr = "sa"; };
        options.ashift = "12";
        datasets = {
          "garage" = { type = "zfs_fs"; options = { encryption = "aes-256-gcm"; keyformat = "passphrase"; keylocation = garageKeylocation; mountpoint = "none"; }; };
          "garage/meta" = { type = "zfs_fs"; mountpoint = "/srv/garage/meta"; options.recordsize = "16K"; };
          "garage/data" = { type = "zfs_fs"; mountpoint = "/srv/garage/data-hdd"; options.recordsize = "1M"; };
        };
      };
    };
  };
}
EOF
}
