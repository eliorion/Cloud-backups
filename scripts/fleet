}

# ============================================================================= menu
cmd_menu() {
  while :; do
    cmd_status || true
    cat <<EOF

  ${B}fleet${R} — node lifecycle
    1) new <node>       scaffold + secrets
    2) install <node>   provision (nixos-anywhere)
    3) finalize <node>  retry post-install unlock (ssh)
    4) deploy <node>    apply config (deploy-rs + rollback)
    5) rollback <node>  previous generation
    6) secrets          edit / verify / commit
    7) config tailnet   set MagicDNS tailnet
    8) guide <node>     on-box fallback runbook
    q) quit
EOF
    local c; c="$(ask 'choice')"
    case "$c" in
      1) cmd_new   "$(ask 'node (a/b/c/d or node-x)')" ${TY:+--type "$TY"} || true; pause;;
      2) local n t; n="$(ask 'node')"; t="$(ask 'target (root@host)')"; cmd_install "$n" "$t" || true; pause;;
      3) local n t; n="$(ask 'node')"; t="$(ask 'target (root@host)')"; cmd_finalize "$n" "$t" || true; pause;;
      4) cmd_deploy   "$(ask 'node')" || true; pause;;
      5) cmd_rollback "$(ask 'node')" || true; pause;;
      6) cmd_secrets || true;;
      7) cmd_config tailnet "$(ask 'tailnet name')" || true; pause;;
      8) cmd_guide "$(ask 'node')" || true; pause;;
      q|Q|"") echo "bye."; return 0;;
      *) warn "unknown choice"; pause;;
    esac
  done
}

# ============================================================================= dispatch
main() {
  [[ -f "$SOPS_YAML" ]] || die "run from inside the garage-fleet repo (.sops.yaml not found at $ROOT)"
  case "${1:-}" in
    new)      shift; cmd_new "$@";;
    install)  shift; cmd_install "$@";;
    finalize) shift; cmd_finalize "$@";;
    deploy)   shift; cmd_deploy "$@";;
    rollback) shift; cmd_rollback "$@";;
    status)   shift; cmd_status "$@";;
    secrets)  shift; cmd_secrets "$@";;
    config)   shift; cmd_config "$@";;
    guide)    shift; cmd_guide "$@";;
    ""|menu)  cmd_menu;;
    -h|--help|help) sed -n '2,40p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//';;
    *) die "unknown command: $1 (try: fleet --help)";;
  esac
}
main "$@"
