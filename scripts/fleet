#!/usr/bin/env bash
#
# fleet — one entrypoint for the garage-fleet node lifecycle, run from the
#         devcontainer (the workstation). Replaces scripts/bootstrap-node +
#         scripts/deploy-node.
#
# Commands:
#   fleet                       Interactive TUI menu.
#   fleet new   <node> [opts]   Scaffold + secrets for a node (idempotent).
#                               Generates the fleet age key, shared secrets, the
#                               node's DEDICATED age key (-> private-keys/), its age
#                               recipient (-> .sops.yaml), its Tailscale authkey, and
#                               — for a brand-new node — its hosts/*.nix + disko +
#                               flake + .sops.yaml rule. (No SSH host key: sshd
#                               generates its own on first boot.)
#                               Re-running SKIPS what already exists; --force regens.
#   fleet install <node> <root@host>
#                               First provision over the network with
#                               nixos-anywhere. Feeds the ZFS passphrase to the
#                               installer's RAM (--disk-encryption-keys), seeds the
#                               host key (--extra-files), then restores
#                               keylocation=prompt. DESTROYS the target's disks.
#   fleet deploy  <node> [--detached] [-- ...]
#                               Apply a config change to an already-installed node
#                               with deploy-rs (magic-rollback auto-reverts a bad
#                               firewall/tailscaled change). First push warns: no
#                               rollback baseline yet — keep a console reachable.
#                               --detached: activate over the tailnet WITHOUT a
#                               held ssh (switch runs under systemd/PID1, so it
#                               survives the tailscaled restart it triggers). This
#                               is the NO-LAN path for tailscale version/config
#                               changes on an offsite node — the one class that
#                               breaks a normal (held-ssh) deploy. No magic-rollback
#                               on this path (see the warning it prints).
#   fleet rollback <node>       Manually roll the node back one generation (ssh).
#   fleet unlock  <node> [root@host]
#                               Feed the ZFS passphrase to a locked node over ssh
#                               (load-key every locked pool + mount + start garage).
#                               Use when `fleet status` shows garage down post-reboot.
#   fleet status  [<node>]      Readiness + lifecycle state per node.
#   fleet secrets               Edit / verify / git-add the encrypted secrets.
#   fleet config tailnet <name> Set the MagicDNS tailnet in flake.nix.
#   fleet layout <show|apply>   Garage cluster layout (zone + capacity per node).
#                               apply reads each host's fleet.zone + fleet.garageCapacity,
#                               fetches live node ids, and assigns + applies version+1
#                               from the workstation (layout is imperative cluster state,
#                               not garage.toml). Needs all layout nodes up (quorum).
#   fleet buckets <keygen|apply|status|browse>
#                               Declarative Garage S3 buckets + access keys for the
#                               backup consumers (etcd + CNPG). keygen mints the key
#                               material into secrets/s3-keys.enc.yaml (workstation-
#                               only, NEVER on a node); apply creates the buckets +
#                               imports the keys + grants them on a live storage node
#                               (idempotent — the reprovision path); status shows the
#                               live state; browse <bucket> opens a READ-ONLY web
#                               object browser (ssh tunnel + rclone serve http on
#                               localhost — no server on the cluster). Edit the
#                               bucket/key spec in the buckets section of this script.
#   fleet guide   <node>        Print the on-box fallback runbook (doc 04).
#
# Tool needs:
#   new / secrets : nix (purego sops/age from the flake), openssl, git.
#                   sops/age MUST be the flake's -tags=purego builds — a stock/mise
#                   binary silently corrupts age ciphertext on this Rosetta
#                   (Apple-Silicon) workstation (see sops()/age()). Node identity is
#                   ONE DEDICATED age key (private-keys/<node>-age.txt); the SSH host
#                   key is not managed here (sshd self-generates it on first boot).
#   install/deploy/rollback : nix (+ ssh)  — these build/activate the flake
# Secrets are never echoed. private-keys/ + node-*-extra/ are gitignored and
# never staged. Only ENCRYPTED secrets/*.enc.yaml are committed.
set -euo pipefail

# ----------------------------------------------------------------------------- paths
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SECRETS="$ROOT/secrets"
SOPS_YAML="$ROOT/.sops.yaml"
COMMON="$SECRETS/common.enc.yaml"
HOSTS="$ROOT/hosts"
FLAKE="$ROOT/flake.nix"
PRIVKEYS="$ROOT/private-keys"
STATE_DIR="$ROOT/.fleet"

# Must match flake.nix `installKeyfile` (the tmpfs path nixos-anywhere uploads
# the ZFS passphrase to, that the *-install disko variants read).
INSTALL_KEYFILE_REMOTE="/tmp/fleet-zfs.key"
# Must match hosts/disko-node-a.nix `luksInstallKeyfile` — the tmpfs path the
# cryptwork LUKS passphrase is uploaded to (LUKS-root nodes only; node-A).
INSTALL_LUKS_KEYFILE_REMOTE="/tmp/fleet-luks.key"

# Fleet age private key (decrypts sops as the workstation). In-repo copy first
# (private-keys/, gitignored), then the XDG location, then env override.
FLEET_AGE_KEY_FILE="${FLEET_AGE_KEY_FILE:-$PRIVKEYS/garage-fleet.txt}"
[[ -f "$FLEET_AGE_KEY_FILE" ]] || FLEET_AGE_KEY_FILE="$HOME/.config/sops/age/garage-fleet.txt"
export SOPS_AGE_KEY_FILE="$FLEET_AGE_KEY_FILE"

FORCE=0

# ----------------------------------------------------------------------------- ui
if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
  B=$'\e[1m'; R=$'\e[0m'; G=$'\e[32m'; Y=$'\e[33m'; RED=$'\e[31m'; C=$'\e[36m'; D=$'\e[90m'
else
  B=''; R=''; G=''; Y=''; RED=''; C=''; D=''
fi
# Status glyph for the status table: SINGLE display cell each (U+2713/2717/00B7 —
# NOT the heavy ✔/✘ U+2714/2718, which take an emoji-presentation double cell and
# break column alignment). Colour codes have zero display width, so a cell is
# printed as "glyph + literal spaces" and the columns line up regardless of colour.
mk() {
  case "$1" in
    ok) printf '%s✓%s' "$G"   "$R" ;;
    no) printf '%s✗%s' "$RED" "$R" ;;
    *)  printf '%s·%s' "$D"   "$R" ;; # na / not-yet
  esac
}
# Live, best-effort: is garage.service active on the node? Probes over ssh
# (root@<node>, relying on the ~/.ssh/config alias / MagicDNS the operator uses).
# Short timeout so an offline or still-locked node cannot hang `fleet status`.
# Echoes ok (active) / no (inactive|failed) / na (unreachable). Callers run this
# in the background per node so the whole fleet is probed in parallel.
probe_garage() {
  local out
  out="$(ssh -o BatchMode=yes -o ConnectTimeout=3 -o StrictHostKeyChecking=accept-new \
           "root@$1" 'systemctl is-active garage.service' 2>/dev/null)" || true
  case "$out" in
    active) echo ok ;;
    "")     echo na ;; # unreachable / down
    *)      echo no ;; # inactive / failed
  esac
}
# Live tailscale0 IPv4 of a node over ssh (root@<node>, same alias/MagicDNS basis as
# probe_garage). Echoes the IP, or empty if unreachable. Run in the background per
# node so the whole fleet is probed in parallel.
probe_tsip() {
  ssh -o BatchMode=yes -o ConnectTimeout=3 -o StrictHostKeyChecking=accept-new \
    "root@$1" 'tailscale ip -4 2>/dev/null | head -1' 2>/dev/null || true
}
ok()   { printf '%s✔%s %s\n' "$G" "$R" "$*"; }
warn() { printf '%s⚠%s %s\n' "$Y" "$R" "$*"; }
err()  { printf '%s✘%s %s\n' "$RED" "$R" "$*" >&2; }
note() { printf '%s•%s %s\n' "$C" "$R" "$*"; }
hdr()  { printf '\n%s== %s ==%s\n' "$B" "$*" "$R"; }
ask()  { local p="$1" d="${2:-}" a; read -rp "$p${d:+ [$d]}: " a; printf '%s' "${a:-$d}"; }
confirm() { local a; read -rp "$1 [y/N]: " a; [[ "$a" =~ ^[Yy]$ ]]; }
pause() { read -rsp "Press Enter to continue…" _; echo; }
die()  { err "$*"; exit 1; }

have() { command -v "$1" >/dev/null 2>&1; }
need() { have "$1" || die "required tool not found: $1"; }

# sops / age / age-keygen — the flake's PUREGO builds ONLY (flake.nix withPurego).
# A stock or mise binary SILENTLY corrupts age ciphertext on this workstation: it is
# x86_64 emulated under Rosetta on an Apple-Silicon Mac, and Rosetta mis-translates
# Go's asm ChaCha20-Poly1305, so files encrypted here are undecryptable by the real
# nodes (sops-nix activation fails "0 successful groups required, got 0"). The purego
# build uses the generic Go path, which Rosetta translates correctly. Resolve the
# store paths ONCE (nix build, cached) so the interactive menus stay snappy, then
# shadow the PATH binaries so every `sops`/`age` call below is the safe one.
_SOPS_BIN=""; _AGE_BIN=""; _AGEKEYGEN_BIN=""
_purego_resolve() {
  [[ -n "$_SOPS_BIN" ]] && return 0
  require_nix "secrets"
  local sd ad
  sd="$(nix build --no-link --print-out-paths "$ROOT#sops" 2>/dev/null)" || die "could not build the purego sops (nix build $ROOT#sops)"
  ad="$(nix build --no-link --print-out-paths "$ROOT#age"  2>/dev/null)" || die "could not build the purego age (nix build $ROOT#age)"
  _SOPS_BIN="$sd/bin/sops"; _AGE_BIN="$ad/bin/age"; _AGEKEYGEN_BIN="$ad/bin/age-keygen"
}
sops()       { _purego_resolve; "$_SOPS_BIN" "$@"; }
age()        { _purego_resolve; "$_AGE_BIN" "$@"; }
age_keygen() { _purego_resolve; "$_AGEKEYGEN_BIN" "$@"; }

require_nix() {
  have nix && return 0
  err "nix is required for '$1' but is not on PATH."
  note "'new'/'secrets' now need nix too — sops/age come from the flake's purego builds"
  note "(a stock/mise sops corrupts ciphertext under Rosetta). 'status' works without nix."
  note "Install nix here if you must: sh <(curl -L https://install.determinate.systems/nix) (then reopen the shell)"
  exit 1
}

# ----------------------------------------------------------------------------- node model
# node arg -> canonical "node-x". Accepts "a", "node-a".
canon() {
  local n="${1#node-}"; n="$(printf '%s' "$n" | tr '[:upper:]' '[:lower:]')"
  [[ "$n" =~ ^[a-z]([a-z0-9-]*[a-z0-9])?$ ]] || die "bad node name: $1 (use a letter like 'a' or 'node-a')"
  printf 'node-%s' "$n"
}
suffix() { printf '%s' "${1#node-}"; }          # node-a -> a
upsfx()  { suffix "$1" | tr '[:lower:]' '[:upper:]'; }

# Type by letter for the canonical fleet; else from --type / existing host file.
TYPE_OVERRIDE=""
type_of() {
  local node="$1" s; s="$(suffix "$node")"
  if [[ -n "$TYPE_OVERRIDE" ]]; then printf '%s' "$TYPE_OVERRIDE"; return; fi
  case "$s" in
    a) printf A;; b) printf B;; c) printf C;; d) printf D;;
    *)
      # Infer from an existing scaffolded host file, else require --type.
      local hf="$HOSTS/$node.nix"
      if [[ -f "$hf" ]]; then
        if grep -q 'workstation.nix' "$hf"; then printf A
        elif grep -q 'role = "gateway"' "$hf"; then printf D
        elif grep -q 'proxyNode = true' "$hf"; then printf B
        else printf B; fi
      else
        die "cannot infer type for $node — pass --type A|B|C|D"
      fi;;
  esac
}
is_storage() { [[ "$(type_of "$1")" != D ]]; }   # A/B/C are storage (encrypted)
type_desc() {
  case "$1" in
    A) printf 'workstation + storage (onsite)';;
    B) printf 'storage + proxy (offsite)';;
    C) printf 'storage + proxy (offsite)';;
    D) printf 'gateway (proxy only, no data)';;
  esac
}
# Compact role for the fixed-width status table (≤21 chars).
type_short() {
  case "$1" in
    A) printf 'onsite storage + ws';;
    B) printf 'offsite-1 store+proxy';;
    C) printf 'offsite-2 store+proxy';;
    D) printf 'gateway (no data)';;
    *) printf '?';;
  esac
}

encrypted() { [[ -f "$1" ]] && grep -q '^sops:' "$1"; }
recipient_set() { ! grep -q 'age1FLEET_PLACEHOLDER_REPLACE_ME' "$SOPS_YAML"; }
# uncommented *node_<s> reference INSIDE the common creation_rule (not just the
# per-node rule) — proves the node is a recipient of common.enc.yaml.
node_in_common_rule() {
  awk -v s="$1" '
    /^[[:space:]]*-[[:space:]]*path_regex:/ { inc = ($0 ~ /common/) ? 1 : 0 }
    inc && $0 ~ ("^[[:space:]]*-[[:space:]]*\\*node_" s "([^a-z0-9]|$)") { found=1 }
    END { exit found?0:1 }
  ' "$SOPS_YAML"
}
# Fully ready = keys anchor filled AND referenced in the common rule, so an
# interrupted half-run is correctly seen as NOT ready and re-run/self-heals.
node_recipient_ready() {
  local s; s="$(suffix "$1")"
  grep -qE "^[[:space:]]*-[[:space:]]*&node_${s}[[:space:]]+age1" "$SOPS_YAML" && node_in_common_rule "$s"
}
# Each node's DEDICATED age identity (age-keygen) — the ONLY per-node key fleet
# manages. Private half kept here (gitignored, break-glass), seeded at install to
# /var/lib/sops-nix/key.txt (modules/sops.nix age.keyFile). THIS is what the secrets
# are encrypted to. (The SSH host key is NOT seeded — sshd generates its own on
# first boot; it is only the node's SSH server fingerprint, not the sops identity.)
node_age_key_path()  { printf '%s/%s-age.txt' "$PRIVKEYS" "$1"; }
node_age_recipient() { age_keygen -y "$(node_age_key_path "$1")" 2>/dev/null | tr -d '[:space:]'; }
committed() { git -C "$ROOT" ls-files --error-unmatch "$1" >/dev/null 2>&1; }
tailnet_set() { ! grep -q 'tailnet = "<tailnet>";' "$FLAKE"; }
# node is wired into flake.nix `hosts` (commented/in-prod-additive nodes are not).
flake_has_node() { grep -qE "^[[:space:]]*${1}[[:space:]]*=[[:space:]]*\./hosts/${1}\.nix;" "$FLAKE"; }

# ============================================================================= new
ensure_fleet_key() {
  local wired; wired="$(grep -oP '&fleet_workstation \Kage1[0-9a-z]+' "$SOPS_YAML" | head -1 || true)"
  if [[ -f "$FLEET_AGE_KEY_FILE" ]]; then
    ok "fleet age key present ($FLEET_AGE_KEY_FILE)"
  elif [[ -n "$wired" ]]; then
    # A real recipient is already committed but we hold no private key. Generating
    # a new one would orphan every committed secret — refuse and demand the real one.
    die "fleet age key missing ($FLEET_AGE_KEY_FILE) but .sops.yaml already targets $wired.
   Restore that private key (break-glass copy) to $FLEET_AGE_KEY_FILE — do NOT generate a
   new one, or every committed secret becomes undecryptable. (Intentional rotation: keep the
   OLD key present and re-key the secrets with 'fleet secrets' -> re-encrypt.)"
  else
    mkdir -p "$(dirname "$FLEET_AGE_KEY_FILE")"
    ( umask 077; age_keygen -o "$FLEET_AGE_KEY_FILE" >/dev/null 2>&1 )
    ok "generated fleet age key ($FLEET_AGE_KEY_FILE)"
    warn "BREAK-GLASS: copy this private key OFFLINE to two locations — losing it"
    warn "             makes every committed secret undecryptable from the workstation."
  fi
  local recip; recip="$(age_keygen -y "$FLEET_AGE_KEY_FILE")"
  if [[ -n "$wired" ]]; then
    [[ "$wired" == "$recip" ]] || die "local fleet key recipient ($recip) != .sops.yaml ($wired) — wrong/old key in $FLEET_AGE_KEY_FILE."
    ok "fleet recipient matches .sops.yaml"
  else
    sed -i "s|age1FLEET_PLACEHOLDER_REPLACE_ME|${recip}|" "$SOPS_YAML"
    ok "wrote fleet recipient into .sops.yaml"
  fi
}

ensure_common_secrets() {
  if encrypted "$COMMON" && [[ "$FORCE" != 1 ]]; then
    ok "shared secrets present (secrets/common.enc.yaml)"
    return
  fi
  if encrypted "$COMMON"; then
    confirm "common.enc.yaml exists — ROTATE rpc/admin/metrics tokens?" || { ok "kept existing shared secrets"; return; }
  fi
  trap 'rm -f "$COMMON"' INT TERM   # scrub plaintext if interrupted before encrypt
  ( umask 077
    {
      printf 'rpc_secret: "%s"\n'   "$(openssl rand -hex 32)"
      printf 'admin_token: "%s"\n'  "$(openssl rand -hex 32)"
      printf 'metrics_token: "%s"\n' "$(openssl rand -hex 32)"
    } > "$COMMON"
  )
  sops --config "$SOPS_YAML" -e -i "$COMMON"
  trap - INT TERM
  encrypted "$COMMON" || die "encryption of common.enc.yaml failed"
  ok "generated + encrypted shared secrets (rpc/admin/metrics)"
  note "ZFS passphrase is NOT stored here — typed at format + each unlock (prompt-unlock)."
}

# The node's DEDICATED age identity — what secrets/*.enc.yaml are encrypted to and
# what gets seeded to /var/lib/sops-nix/key.txt at install. Generated once, kept in
# private-keys/ (gitignored). Losing it = re-key that node.
ensure_node_age_key() {
  local node="$1" ak; ak="$(node_age_key_path "$node")"
  if [[ -f "$ak" && "$FORCE" != 1 ]]; then
    ok "node age key present ($ak)"; return
  fi
  if [[ -f "$ak" && "$FORCE" == 1 ]]; then
    warn "REGENERATING $node age key — its recipient changes; .sops.yaml + updatekeys must follow."
    confirm "really regenerate $node age key?" || { ok "kept existing age key"; return; }
  fi
  mkdir -p "$PRIVKEYS"; chmod 700 "$PRIVKEYS"
  ( umask 077; age_keygen -o "$ak" >/dev/null 2>&1 )
  ok "generated node age key ($ak)"
  warn "BREAK-GLASS: this key decrypts $node's secrets. Keep an OFFLINE copy —"
  warn "            losing it means re-keying $node (fleet new $node --force)."
}

# .sops.yaml: ensure the node's age recipient anchor + BOTH references exist
# (keys anchor, common-rule ref, per-node tailscale rule). Idempotent and self-
# healing: a half-applied prior run is completed on the next call.
sops_ensure_recipient() {
  local s="$1" recip="$2" up; up="$(printf '%s' "$s" | tr '[:lower:]' '[:upper:]')"
  # --- keys-block anchor ---
  if grep -q "age1NODE${up}_PLACEHOLDER_REPLACE_ME" "$SOPS_YAML"; then
    sed -i "s|#- &node_${s} age1NODE${up}_PLACEHOLDER_REPLACE_ME|- \&node_${s} ${recip}|" "$SOPS_YAML"
    ok "filled .sops.yaml anchor for node_${s}"
  elif grep -qE "^[[:space:]]*-[[:space:]]*&node_${s}[[:space:]]+age1" "$SOPS_YAML"; then
    if [[ "$FORCE" == 1 ]]; then
      sed -i -E "s|^([[:space:]]*-[[:space:]]*&node_${s}[[:space:]]+)age1[0-9a-z]+|\1${recip}|" "$SOPS_YAML"
      ok "updated .sops.yaml anchor for node_${s} (--force)"
    fi
  else
    sops_insert_anchor "$s" "$recip"
    ok "inserted .sops.yaml anchor for node_${s}"
  fi
  # --- common-rule + tailscale refs (ALWAYS; self-heals an interrupted run) ---
  sed -i "s|#- \*node_${s}|- *node_${s}|g" "$SOPS_YAML"   # uncomment any commented refs
  node_in_common_rule "$s" || sops_insert_common_ref "$s"
  sops_ensure_ts_rule "$s"
}

# Append a keys-block anchor after the last existing node anchor (node-e+ path).
sops_insert_anchor() {
  local s="$1" recip="$2" tmp; tmp="$(mktemp)"
  awk -v line="  - &node_${s} ${recip}" '
    /(^|[[:space:]])(#?- )&node_/ { last=NR }
    { rows[NR]=$0 }
    END { for (i=1;i<=NR;i++){ print rows[i]; if (i==last) print line } }
  ' "$SOPS_YAML" > "$tmp" && mv "$tmp" "$SOPS_YAML"
}

# Insert *node_<s> into the common creation_rule's age list (after its last ref).
sops_insert_common_ref() {
  local s="$1" tmp; tmp="$(mktemp)"
  awk -v ref="          - *node_${s}" '
    /^[[:space:]]*-[[:space:]]*path_regex:/ { incommon = ($0 ~ /common/) ? 1 : 0 }
    { rows[NR]=$0; if (incommon && $0 ~ /[*](fleet_workstation|node_)/) last=NR }
    END { for (i=1;i<=NR;i++){ print rows[i]; if (i==last) print ref } }
  ' "$SOPS_YAML" > "$tmp" && mv "$tmp" "$SOPS_YAML"
}

# Ensure a per-node tailscale creation_rule exists (append if absent).
sops_ensure_ts_rule() {
  local s="$1"
  grep -qE "path_regex: secrets/node-${s}\\.enc" "$SOPS_YAML" && return 0
  cat >> "$SOPS_YAML" <<EOF
  - path_regex: secrets/node-${s}\\.enc\\.ya?ml\$
    key_groups:
      - age:
          - *fleet_workstation
          - *node_${s}
EOF
}

ensure_recipient() {
  local node="$1" s; s="$(suffix "$node")"
  if node_recipient_ready "$node" && [[ "$FORCE" != 1 ]]; then
    ok ".sops.yaml recipient for $node ready"; return
  fi
  local recip; recip="$(node_age_recipient "$node")"
  [[ "$recip" == age1* ]] || die "no dedicated age key for $node — run: fleet new $node (generates $(node_age_key_path "$node"))"
  sops_ensure_recipient "$s" "$recip"
}

ensure_authkey() {
  local node="$1"; local tsfile="$SECRETS/$node.enc.yaml"
  if encrypted "$tsfile" && [[ "$FORCE" != 1 ]]; then
    ok "Tailscale authkey present ($tsfile)"; return
  fi
  if encrypted "$tsfile"; then
    confirm "$node authkey exists — REPLACE it?" || { ok "kept existing authkey"; return; }
  fi
  note "Mint a REUSABLE, NON-EPHEMERAL, tag:garage auth key in the Tailscale admin console."
  local key; read -rsp "Paste $node auth key (tskey-…, hidden, blank to skip): " key; echo
  if [[ -z "$key" ]]; then warn "skipped authkey for $node (do 'fleet new $node' again when you have it)"; return; fi
  [[ "$key" == tskey-* ]] || warn "that does not look like a tskey-… key — storing anyway"
  trap 'rm -f "$tsfile"' INT TERM   # scrub plaintext if interrupted before encrypt
  ( umask 077; printf 'authkey: "%s"\n' "$key" > "$tsfile" )
  sops --config "$SOPS_YAML" -e -i "$tsfile"
  trap - INT TERM
  encrypted "$tsfile" || die "encryption of $tsfile failed"
  ok "stored + encrypted $node authkey"
}

# Scaffold hosts/<node>.nix + disko + hardware placeholder + flake `hosts` entry
# for a brand-new node. Skips anything that already exists. Canonical a-d are
# already in-tree, so this is a no-op for them.
scaffold_nix() {
  local node="$1" type; type="$(type_of "$node")"
  local hf="$HOSTS/$node.nix" df="$HOSTS/disko-$node.nix" hw="$HOSTS/$node-hardware.nix"
  local hostid; hostid="$(openssl rand -hex 4)"

  if [[ -f "$hf" ]]; then ok "host config exists ($hf)"; else
    local zone tsip; tsip="100.64.0.x"
    case "$type" in A) zone=onsite;; B) zone=offsite-1;; C) zone=offsite-2;; D) zone="";; esac
    [[ "$type" != D ]] && zone="$(ask "zone label for $node" "$zone")"
    case "$type" in
      A) host_template_A ;; B|C) host_template_BC ;; D) host_template_D ;;
    esac | sed -e "s/@NODE@/$node/g" -e "s/@HOSTID@/$hostid/g" -e "s/@ZONE@/$zone/g" -e "s/@TSIP@/$tsip/g" > "$hf"
    ok "scaffolded $hf (TODO: device paths, capacities, tailscaleIp)"
  fi

  if [[ -f "$df" ]]; then ok "disko config exists ($df)"; else
    case "$type" in A) disko_template_A ;; B|C) disko_template_BC ;; D) disko_template_D ;; esac \
      | sed -e "s/@NODE@/$node/g" > "$df"
    ok "scaffolded $df (TODO: confirm device paths with lsblk on the box)"
  fi

  if [[ -f "$hw" ]]; then ok "hardware config exists ($hw)"; else
    hardware_template | sed -e "s/@NODE@/$node/g" > "$hw"
    ok "scaffolded $hw (PLACEHOLDER — fill via nixos-anywhere --generate-hardware-config)"
  fi

  if grep -qE "^[[:space:]]*#?[[:space:]]*${node}[[:space:]]*=[[:space:]]*\./hosts/${node}\.nix;" "$FLAKE"; then
    ok "flake hosts entry exists for $node"
  else
    local tmp; tmp="$(mktemp)"
    awk -v line="        $node = ./hosts/$node.nix;" '
      /= \.\/hosts\/node-[a-z0-9-]+\.nix;/ { last=NR }
      { rows[NR]=$0 }
      END { for (i=1;i<=NR;i++){ print rows[i]; if (i==last) print line } }
    ' "$FLAKE" > "$tmp" && mv "$tmp" "$FLAKE"
    ok "added $node to flake.nix hosts (derives nixosConfigurations + deploy)"
  fi
}

cmd_new() {
  [[ $# -ge 1 ]] || die "usage: fleet new <node> [--type A|B|C|D] [--force]"
  local node; node="$(canon "$1")"; shift
  while [[ $# -gt 0 ]]; do case "$1" in
    --type) TYPE_OVERRIDE="${2^^}"; shift 2;;
    --force) FORCE=1; shift;;
    *) die "unknown option: $1";;
  esac; done
  for t in openssl git; do need "$t"; done  # sops/age via the purego wrappers (nix)
  [[ -f "$SOPS_YAML" ]] || die "run from the repo (.sops.yaml not found)"
  local type; type="$(type_of "$node")"
  hdr "new $node — type $type ($(type_desc "$type"))"
  ensure_fleet_key
  ensure_common_secrets
  scaffold_nix "$node"
  ensure_node_age_key "$node"
  ensure_recipient "$node"
  ensure_authkey "$node"
  hdr "re-encrypt to the current recipient set"
  sops --config "$SOPS_YAML" updatekeys -y "$COMMON" >/dev/null && ok "updatekeys common.enc.yaml"
  local tsfile="$SECRETS/$node.enc.yaml"
  [[ -f "$tsfile" ]] && { sops --config "$SOPS_YAML" updatekeys -y "$tsfile" >/dev/null && ok "updatekeys $node tailscale"; }
  sops -d "$COMMON" >/dev/null 2>&1 && ok "workstation decrypt check OK" || warn "decrypt check failed (is the fleet age key present?)"
  hdr "next"
  note "Review the scaffolded hosts/$node.nix + disko (device paths, capacity, hostId)."
  note "Commit the ENCRYPTED secrets:   fleet secrets   (verify + git add), then git commit."
  note "Provision it:                   fleet install $node root@<installer-ip>"
}

# Remote tmpfs path this node's cryptwork LUKS passphrase must be uploaded to, or
# empty if the node has no LUKS root. Evals fleet.luksInstallKeyfile on the
# `-install` variant (null → `nix eval --raw` errors → treated as empty). Needs nix.
node_luks_keyfile() {
  local node="$1" v
  v="$( ( cd "$ROOT" && nix eval --raw ".#nixosConfigurations.${node}-install.config.fleet.luksInstallKeyfile" ) 2>/dev/null )" || return 0
  [[ -n "$v" && "$v" != "null" ]] && printf '%s' "$v"
  return 0
}

# ============================================================================= install
cmd_install() {
  [[ $# -ge 2 ]] || die "usage: fleet install <node> <root@host> [-- <extra nixos-anywhere args>]"
  local node target; node="$(canon "$1")"; target="$2"; shift 2
  local extra=(); [[ "${1:-}" == -- ]] && { shift; extra=("$@"); }
  require_nix install
  need ssh
  [[ "$target" == *@* ]] || die "target must be user@host (e.g. root@192.0.2.10)"
  local ak; ak="$(node_age_key_path "$node")"
  [[ -f "$ak" ]] || die "no dedicated age key for $node ($ak) — run: fleet new $node"
  encrypted "$COMMON" || die "secrets/common.enc.yaml is not encrypted — run: fleet new $node"
  node_recipient_ready "$node" || die "$node recipient missing in .sops.yaml — run: fleet new $node"
  # Chicken-and-egg guard (a DESTRUCTIVE-wipe check): the dedicated age key about to
  # be SEEDED (--extra-files -> /var/lib/sops-nix/key.txt) is this node's sops-nix
  # identity. If its recipient is NOT what the secrets were encrypted to, sops-nix
  # fails at first-boot activation → no tailscale-authkey → the node never joins the
  # mesh → the dpool `zfs load-key` unlock (only reachable over the mesh) is
  # impossible on freshly wiped disks. Verify BEFORE wiping.
  local seeded_recip; seeded_recip="$(node_age_recipient "$node")"
  [[ "$seeded_recip" == age1* ]] || die "cannot read a recipient from $ak."
  grep -q "$seeded_recip" "$SOPS_YAML" || die "$node's age key ($ak) has recipient $seeded_recip, which is NOT in .sops.yaml — the secrets are encrypted to a DIFFERENT key, so $node could not decrypt them after install (no mesh, no unlock). Re-run 'fleet new $node' or re-encrypt to this key first."
  committed "secrets/common.enc.yaml" || die "commit the encrypted secrets first (fleet secrets). A flake copies only git-tracked files."
  committed "hosts/$node.nix" || warn "hosts/$node.nix is not committed — the flake build will not see uncommitted files."
  flake_has_node "$node" || die "$node is not wired into flake.nix (its hosts entry is missing/commented). For an in-production additive node (e.g. node-d), wire its hardware-config and uncomment it in hosts/$node.nix + flake.nix hosts first."

  local type; type="$(type_of "$node")"
  hdr "install $node ($type) -> $target   [DESTROYS the target's disks]"
  warn "disko create-mode WIPES all disks listed in hosts/disko-$node.nix."
  note "Confirm device paths there match 'lsblk' on the installer BEFORE proceeding."
  confirm "wipe + install $node on $target?" || { note "aborted."; return; }

  # Prompt the passphrase(s) BEFORE creating any temp file, so a typo aborts cleanly.
  local flake_attr=".#${node}-install" p1="" pl="" luks_remote=""
  if is_storage "$node"; then
    local p2
    note "ZFS (dpool) passphrase — the MANUAL gate you re-type over the mesh each unlock."
    note "Uploaded to the installer's RAM only (tmpfs $INSTALL_KEYFILE_REMOTE); keylocation"
    note "is restored to prompt post-boot — never written to any disk, here or on the box."
    read -rsp "ZFS (dpool) passphrase for $node (hidden): " p1; echo
    read -rsp "confirm ZFS passphrase: " p2; echo
    [[ -n "$p1" && "$p1" == "$p2" ]] || die "passphrases empty or mismatched"

    # LUKS-root nodes (node-A) need a SECOND, DIFFERENT install passphrase: the
    # cryptwork keyslot-0 secret = the TPM recovery key. Kept separate from the
    # dpool passphrase (different domains, different rotation, different exposure).
    luks_remote="$(node_luks_keyfile "$node")"
    if [[ -n "$luks_remote" ]]; then
      local pl2
      warn "$node has a LUKS/TPM root — this is a SECOND passphrase, DIFFERENT from the ZFS"
      warn "one above (LUKS keyslot-0 = TPM recovery secret). BOTH go in your password"
      warn "manager; the LUKS one is the ONLY way back if a firmware update rotates PCR 7."
      read -rsp "LUKS (root) install passphrase for $node (hidden): " pl; echo
      read -rsp "confirm LUKS passphrase: " pl2; echo
      [[ -n "$pl" && "$pl" == "$pl2" ]] || die "LUKS passphrases empty or mismatched"
      [[ "$pl" == "$p1" ]] && warn "LUKS and ZFS passphrases are IDENTICAL — allowed, but a distinct LUKS passphrase is stronger."
    fi
  else
    flake_attr=".#${node}"   # gateway has no encrypted pool; no install variant needed
  fi

  # Throwaway trees: --extra-files (host key) + the passphrase keyfile. A process
  # substitution would be dead by the time nixos-anywhere reads it, so the
  # passphrase goes to a mode-600 temp FILE (NOT under $xf — that tree is copied
  # onto the target). Both are cleaned on RETURN; we capture nixos-anywhere's exit
  # status so a failure RETURNS (firing the trap) instead of aborting under set -e
  # and leaking the private host key.
  local xf kf_src="" kl_src=""
  xf="$(mktemp -d)"
  trap 'rm -rf "$xf" ${kf_src:+"$kf_src"} ${kl_src:+"$kl_src"}' RETURN
  # The node's DEDICATED age identity -> /var/lib/sops-nix/key.txt (modules/sops.nix
  # age.keyFile) is the ONLY thing seeded. WITHOUT it the node has no sops identity
  # and first-boot activation cannot decrypt ANY secret. Mode 0400 root (the tree is
  # copied as-is). The SSH host key is NOT seeded — sshd generates its own on first
  # boot (so a reinstall changes the node's SSH fingerprint: ssh-keygen -R <host>).
  install -d -m700 "$xf/var/lib/sops-nix"
  install -m400 "$ak" "$xf/var/lib/sops-nix/key.txt"
  local dek=()
  if is_storage "$node"; then
    kf_src="$(mktemp)"; chmod 600 "$kf_src"; printf '%s' "$p1" > "$kf_src"
    dek=(--disk-encryption-keys "$INSTALL_KEYFILE_REMOTE" "$kf_src")
    # Second pair for the LUKS root (node-A): its own passphrase, its own tmpfs path.
    if [[ -n "$luks_remote" ]]; then
      kl_src="$(mktemp)"; chmod 600 "$kl_src"; printf '%s' "$pl" > "$kl_src"
      dek+=(--disk-encryption-keys "$luks_remote" "$kl_src")
    fi
  fi

  hdr "nixos-anywhere"
  local rc=0
  set +e
  # .#nixos-anywhere (not the bare github: ref) so flake.lock pins the rev — the
  # tool that formats the disks must not float between installs.
  ( cd "$ROOT" && nix run ".#nixos-anywhere" -- \
      --flake "$flake_attr" "${dek[@]}" --extra-files "$xf" "${extra[@]}" "$target" )
  rc=$?
  set -e
  [[ $rc -eq 0 ]] || { err "nixos-anywhere failed (rc=$rc) — nothing finalized."; return 1; }
  mkdir -p "$STATE_DIR"; : > "$STATE_DIR/installed-$node"
  ok "nixos-anywhere finished — $node rebooted into the installed system."

  if is_storage "$node"; then
    hdr "post-boot: restore prompt-unlock + bring Garage up"
    note "The install keyfile is gone (tmpfs). Switch the encrypted datasets back to"
    note "prompt-unlock and unlock them now (you'll re-type the SAME ZFS passphrase)."
    if [[ -n "$luks_remote" ]]; then
      warn "$node has a LUKS/TPM root and the TPM is NOT enrolled yet, so THIS first boot"
      warn "STOPS at a console LUKS passphrase prompt. Be at the keyboard: type the LUKS"
      warn "passphrase within ~60s of the prompt — sshd (and this finalize) only come up"
      warn "after that. Future reboots go unattended once you enroll the TPM (see 'next')."
    fi
    # The box is REBOOTING into the installed system; sshd is not listening yet, so
    # finalizing immediately fails with "Connection refused". Wait for it.
    wait_for_ssh "$target" || {
      warn "$target did not come back within the timeout — finalize skipped."
      print_finalize "$target" "$node"
      return 0
    }
    if confirm "run the finalize over ssh -t $target now?"; then
      finalize_storage "$target"
    else
      print_finalize "$target" "$node"
    fi
  fi

  hdr "next"
  note "Note $node's tailnet IP ('tailscale status' on the box), set fleet.tailscaleIp,"
  note "set the tailnet ('fleet config tailnet <name>'), commit, then: fleet deploy $node"
  note "Apply the Garage layout ONCE (prev+1) — see: fleet guide $node"
  if [[ -n "$luks_remote" ]]; then
    warn "SECURE BOOT + TPM ($node, ONE-TIME console trip) — do the enrollment runbook in"
    warn "modules/secureboot.nix: sbctl create-keys → flip fleet.secureBoot=true + deploy →"
    warn "enroll keys + enable Secure Boot in firmware → systemd-cryptenroll the TPM to PCR 7."
    warn "Until the TPM is sealed, EVERY boot needs the console LUKS passphrase."
  fi
}

# Poll until the target's sshd answers. nixos-anywhere reboots the box at the end
# of the install, so anything that ssh's immediately hits "Connection refused"
# (port closed, host already up) — a race, not a failure. Also re-keys the host in
# known_hosts: the installed system serves the host key we SEEDED, not the
# installer's ephemeral one, so ssh would otherwise abort with
# "REMOTE HOST IDENTIFICATION HAS CHANGED".
wait_for_ssh() {
  local target="$1" tries="${2:-60}" host="${target#*@}" i=0
  note "waiting for $host to finish rebooting and start sshd…"
  ssh-keygen -R "$host" >/dev/null 2>&1 || true
  while (( i < tries )); do
    if ssh -o StrictHostKeyChecking=accept-new -o UserKnownHostsFile="$HOME/.ssh/known_hosts" \
           -o BatchMode=yes -o ConnectTimeout=5 "$target" true >/dev/null 2>&1; then
      ok "$host is up (host key accepted — it is the key seeded via --extra-files)"
      return 0
    fi
    sleep 5; i=$(( i + 1 ))
  done
  return 1
}

# Switch any file://-keyed datasets back to prompt and unlock them. The unlock
# loop is passed as the ssh COMMAND ARGUMENT (not on stdin) so the operator's
# terminal stays free for `zfs load-key`'s interactive passphrase prompt — a
# stdin heredoc would starve it. The passphrase is typed into the box; nothing is
# stored here. Host-key checking is relaxed because this is the box we just
# provisioned seconds ago (brand-new host key, on the LAN).
finalize_storage() {
  local target="$1" remote
  remote='set -e
for ds in $(zfs get -H -o name,value -t filesystem keylocation | awk '\''$2 ~ /^file:/{print $1}'\''); do
  echo ">> $ds: load-key (type the SAME passphrase) then set keylocation=prompt"
  zfs load-key -L prompt "$ds"
  zfs set keylocation=prompt "$ds"
done
zfs mount -a
systemctl start garage || true
systemctl --no-pager --full status garage | head -5 || true'
  ssh -t -o StrictHostKeyChecking=accept-new -o UserKnownHostsFile=/dev/null "$target" "$remote"
  ok "finalize done — encrypted datasets are prompt-unlock again."
}

print_finalize() {
  local target="$1" node="$2"
  cat <<EOF
  Run on $node (over the mesh), typing the SAME passphrase when asked:

    ssh -t $target
    for ds in \$(zfs get -H -o name,value -t filesystem keylocation | awk '\$2 ~ /^file:/{print \$1}'); do
      zfs load-key -L prompt "\$ds" && zfs set keylocation=prompt "\$ds"
    done
    zfs mount -a && systemctl start garage
EOF
}

# ============================================================================= deploy
# Retry the post-install finalize on its own. `install` offers it once, but the box
# is still rebooting at that moment — if that attempt is declined or races the
# reboot, there was previously NO way back except re-wiping the disks. Also imports
# the data pools first: after a fresh install they may not be imported yet, and
# `zfs load-key` on a pool that is not imported fails "dataset does not exist".
cmd_finalize() {
  [[ $# -ge 2 ]] || die "usage: fleet finalize <node> <root@host>"
  local node target; node="$(canon "$1")"; target="$2"
  need ssh
  is_storage "$node" || die "$node is not a storage node — nothing to finalize."
  [[ "$target" == *@* ]] || die "target must be user@host (e.g. root@192.0.2.10)"
  hdr "finalize $node -> $target"
  wait_for_ssh "$target" 12 || die "$target is not answering ssh."
  note "Importing any not-yet-imported data pools, then restoring prompt-unlock."
  note "You will re-type the SAME ZFS passphrase used at install."
  ssh -t -o BatchMode=no "$target" 'for p in $(zpool import 2>/dev/null | awk "/^  pool:/{print \$2}"); do
  echo ">> importing $p"; zpool import "$p" || true
done' || true
  finalize_storage "$target"
}

# ============================================================================= unlock
# Feed the ZFS passphrase to a node whose data pool is LOCKED (garage down after a
# reboot — keylocation=prompt stores no key on the box, doc 03). Reads the
# passphrase locally (hidden prompt, or one line from stdin for scripting), then
# over ssh discovers every locked encryptionroot on the node and loads the key on
# each with that ONE passphrase (npool/garage + dpool/garage share it), `zfs
# mount -a`, and starts garage. Self-contained: does NOT require the garage-ops
# module (garage-unlock) to be deployed yet. The passphrase travels only on ssh
# stdin — never argv/env, so it never lands in the process table.
cmd_unlock() {
  [[ $# -ge 1 ]] || die "usage: fleet unlock <node> [root@host]"
  local node target; node="$(canon "$1")"
  target="${2:-root@$node}"; [[ "$target" == *@* ]] || target="root@$target"
  need ssh
  is_storage "$node" || die "$node is not a storage node — nothing to unlock."
  local pass
  if [[ -t 0 ]]; then
    read -rsp "ZFS passphrase for $node: " pass; echo
  else
    IFS= read -r pass || true
  fi
  [[ -n "$pass" ]] || die "no passphrase given."
  hdr "unlock $node -> $target"
  # Runs as root (default root@ target), so no sudo. Single-quoted so $vars expand
  # ON THE NODE. Reads the passphrase from stdin line 1, loads every LOCKED
  # encryptionroot, mounts, starts garage, prints the result.
  local remote='set -eu
IFS= read -r PASS
n=0
for r in $(zfs get -H -o value encryptionroot 2>/dev/null | sort -u); do
  [ "$r" = - ] && continue
  [ "$(zfs get -H -o value keystatus "$r")" = available ] && continue
  printf "%s" "$PASS" | zfs load-key "$r"
  echo ">> unlocked $r"
  n=$((n+1))
done
if [ "$n" = 0 ]; then echo ">> nothing was locked"; fi
zfs mount -a
systemctl start garage.service
echo ">> garage.service: $(systemctl is-active garage.service || true)"'
  if printf '%s\n' "$pass" | ssh -o BatchMode=yes -o ConnectTimeout=8 "$target" "$remote"; then
    ok "unlock finished on $node."
  else
    die "unlock failed on $node (wrong passphrase, or pool not imported — try: fleet finalize $node $target)."
  fi
}

cmd_deploy() {
  [[ $# -ge 1 ]] || die "usage: fleet deploy <node> [--detached] [-- <extra deploy-rs args>]"
  local node; node="$(canon "$1")"; shift
  local detached=0
  while [[ $# -gt 0 && "$1" != -- ]]; do
    case "$1" in
      --detached) detached=1; shift;;
      *) die "unknown deploy option: $1 (deploy-rs args go after --).";;
    esac
  done
  local extra=(); [[ "${1:-}" == -- ]] && { shift; extra=("$@"); }
  require_nix deploy
  flake_has_node "$node" || die "$node is not wired into flake.nix (hosts entry missing/commented) — wire it before deploying."
  committed "hosts/$node.nix" || warn "hosts/$node.nix not committed — deploy-rs builds from git-tracked files only."
  tailnet_set || die "tailnet still '<tailnet>' in flake.nix — set it: fleet config tailnet <name>"

  if [[ $detached == 1 ]]; then deploy_detached "$node"; return; fi

  hdr "deploy $node (deploy-rs, magic-rollback)"
  if [[ ! -f "$STATE_DIR/deployed-$node" ]]; then
    warn "FIRST deploy-rs push to $node — there is no rollback baseline yet, so a bad"
    warn "firewall/tailscaled change will NOT auto-revert. Keep a console / the box reachable."
    confirm "proceed with the first (no-rollback-baseline) push?" || { note "aborted."; return; }
  else
    note "magic-rollback active: a change that breaks reachability auto-reverts in ~30s."
  fi
  # .#deploy-rs (not the bare github: ref) so flake.lock pins the rev.
  ( cd "$ROOT" && nix run ".#deploy-rs" -- ".#${node}" "${extra[@]}" )
  mkdir -p "$STATE_DIR"; : > "$STATE_DIR/deployed-$node"
  ok "deployed $node (rollback baseline now recorded for next time)."
}

# No-LAN activation for the one deploy class that breaks a held-ssh deploy:
# tailscale version/config changes (the switch restarts tailscaled, which drops the
# very tailnet ssh a normal deploy-rs run rides for its magic-rollback confirm →
# activation dies mid-switch + rollback, and a version rollback then DOWNGRADES
# tailscaled into a state file it cannot parse, bricking garage's RPC bind).
#
# Instead: build the closure locally, `nix copy` it to the node over the tailnet,
# then launch `switch-to-configuration switch` as a transient systemd unit (owned by
# PID 1). systemd-run returns immediately, so when the switch restarts tailscaled and
# THIS ssh drops, the switch keeps running to completion under systemd. The node
# always moves FORWARD (never the downgrade rollback), so a version bump self-heals:
# tailscaled comes back on the new version, migrates its state forward, rejoins the
# tailnet, garage rebinds. We then poll until it is reachable again and report.
#
# Trade-off: there is NO auto-rollback here. A version bump reconnects on its own
# (safe), but a BROKEN tailscale *config* change may never rejoin — with no LAN that
# strands the node. Use --detached for version bumps freely; for config changes keep
# an out-of-band recovery path.
deploy_detached() {
  local node="$1"; need nix; need ssh
  local host; host="$(deploy_host "$node")"
  hdr "deploy $node (--detached: systemd-owned switch over the tailnet, no LAN)"
  warn "NO magic-rollback on this path. A tailscale VERSION bump reconnects on its own"
  warn "(safe); a broken tailscale CONFIG change may never rejoin and, with no LAN,"
  warn "would strand $node. Use freely for version bumps; keep a recovery path for config."
  confirm "detached-deploy $node ($host)?" || { note "aborted."; return; }

  note "building $node's system closure locally..."
  local sys
  sys="$(cd "$ROOT" && nix build --no-link --print-out-paths \
        ".#nixosConfigurations.${node}.config.system.build.toplevel")" \
    || die "build failed."
  note "closure: $sys"

  note "copying closure to $node over the tailnet ($host)..."
  ( cd "$ROOT" && nix copy --to "ssh://root@$host" "$sys" ) \
    || die "nix copy failed — is $host reachable on the tailnet?"

  note "activating DETACHED (switch runs under systemd, survives the tailscaled restart)..."
  # systemd-run launches the switch and returns at once; --collect reaps the transient
  # unit when it finishes. The switch (not this ssh) owns the tailscaled restart.
  ssh -o BatchMode=yes -o ConnectTimeout=10 "root@$host" \
    "nix-env -p /nix/var/nix/profiles/system --set '$sys' && \
     systemd-run --collect --unit=fleet-deploy-switch --property=Type=oneshot \
       '$sys/bin/switch-to-configuration' switch" \
    || die "failed to launch the detached switch on $node."

  ok "switch launched on $node. tailscaled will restart; the tailnet drops briefly."
  note "waiting for $node to rejoin the tailnet (up to ~200s)..."
  local i
  for i in $(seq 1 40); do
    sleep 5
    if ssh -o BatchMode=yes -o ConnectTimeout=6 "root@$host" true 2>/dev/null; then
      ok "$node is reachable again."
      ssh -o BatchMode=yes -o ConnectTimeout=6 "root@$host" \
        'printf "  tailscale: %s\n" "$(tailscale version | head -1)"; \
         printf "  garage.service: %s\n" "$(systemctl is-active garage.service)"' 2>/dev/null || true
      mkdir -p "$STATE_DIR"; : > "$STATE_DIR/deployed-$node"
      note "if garage is not active, its data pool is locked — fleet unlock $node."
      return 0
    fi
  done
  die "$node did NOT rejoin within ~200s. It may still be applying, or the new tailscale
config is broken. Recover over LAN/console and check: journalctl -u fleet-deploy-switch -u tailscaled."
}

cmd_rollback() {
  [[ $# -ge 1 ]] || die "usage: fleet rollback <node>"
  local node; node="$(canon "$1")"; need ssh
  tailnet_set || die "set the tailnet first: fleet config tailnet <name>"
  local host; host="$(deploy_host "$node")"
  hdr "rollback $node -> previous generation"
  warn "This switches $node to its previous NixOS generation over ssh."
  confirm "roll $node ($host) back one generation?" || { note "aborted."; return; }
  ssh -t "root@$host" "nixos-rebuild switch --rollback"
  ok "rolled back $node."
}

deploy_host() {
  local node="$1" tn
  tn="$(grep -oP 'tailnet = "\K[^"]+' "$FLAKE" | head -1)"
  printf '%s.%s.ts.net' "$node" "$tn"
}

# ============================================================================= config
cmd_config() {
  [[ "${1:-}" == tailnet && -n "${2:-}" ]] || die "usage: fleet config tailnet <name>"
  local name="$2"
  sed -i "s|tailnet = \"<tailnet>\";|tailnet = \"${name}\";|" "$FLAKE"
  if tailnet_set; then ok "tailnet set to '$name' in flake.nix"; else
    sed -i -E "s|tailnet = \"[^\"]*\";|tailnet = \"${name}\";|" "$FLAKE"; ok "tailnet updated to '$name'"; fi
}

# ============================================================================= buckets
# Declarative S3 bucket + key spec for the fleet — the SINGLE source of truth.
# Edit here to add/rename a bucket or key.
#   fleet buckets keygen         mint the key material into secrets/s3-keys.enc.yaml
#   fleet buckets apply          create buckets + import keys + grant, on a live node
#   fleet buckets status         show live buckets/keys/permissions
#   fleet buckets browse <bkt>   read-only web browser of a bucket's objects (ssh
#                                tunnel + `rclone serve http` on localhost; no server
#                                on the cluster; secret pulled from sops, torn down on exit)
#
# S3 keys are CONTROL-PLANE credentials: minted + stored ONLY on the workstation
# (secrets/s3-keys.enc.yaml, encrypted to the fleet key, NEVER shipped to a node),
# pushed to a node over ssh only at apply time. So no node stores them, losing any
# one node neither exposes nor blocks the S3 creds, and after ANY rebuild `fleet
# buckets apply` restores identical buckets + credentials (prod jobs never re-wire).
S3KEYS="$SECRETS/s3-keys.enc.yaml"
BUCKETS=(etcd-backup cnpg-staging-asp cnpg-staging-fbref)
# name : id-field : secret-field : bucket[,bucket...]   (fields = flat keys in $S3KEYS)
# One key PER bucket — a leaked key exposes only its own cluster's backups, and a
# compromised prod consumer cannot reach the other cluster's bucket. NOTE: garage
# has only read/write/owner — --write includes DeleteObject (no delete-less grant);
# object immutability is the ZFS snapshot moat, not the key ACL.
S3_KEYS=(
  "etcd-key:s3_etcd_id:s3_etcd_secret:etcd-backup"
  "cnpg-asp-key:s3_cnpg_asp_id:s3_cnpg_asp_secret:cnpg-staging-asp"
  "cnpg-fbref-key:s3_cnpg_fbref_id:s3_cnpg_fbref_secret:cnpg-staging-fbref"
)

# Read one flat field from the (workstation-only) encrypted S3 key file.
s3_get() { sops -d --extract "[\"$1\"]" "$S3KEYS" 2>/dev/null || true; }

# First storage node (a/b/c) reachable over the tailnet WITH garage up — bucket
# ops need the RPC socket live. Echoes the host; non-zero if none reachable.
reachable_storage_node() {
  tailnet_set || die "tailnet unset — set it first: fleet config tailnet <name>"
  local n host
  for n in node-a node-b node-c; do
    [[ -f "$HOSTS/$n.nix" ]] || continue
    host="$(deploy_host "$n")"
    if [[ "$(ssh -o BatchMode=yes -o ConnectTimeout=4 "root@$host" \
              'systemctl is-active garage.service' 2>/dev/null)" == active ]]; then
      printf '%s' "$host"; return 0
    fi
  done
  return 1
}

cmd_buckets() {
  case "${1:-}" in
    keygen) shift; buckets_keygen "$@";;
    apply)  shift; buckets_apply  "$@";;
    status) shift; buckets_status "$@";;
    browse) shift; buckets_browse "$@";;
    ""|-h|--help) note "usage: fleet buckets <keygen|apply|status|browse>";;
    *) die "unknown buckets subcommand: $1 (keygen|apply|status|browse)";;
  esac
}

# Mint any MISSING S3 key material into $S3KEYS. Idempotent — a present key is
# NEVER overwritten (that would orphan the live cluster + prod creds). Pure
# workstation-local: GK+24hex id + 64hex secret (garage's format), no node needed.
buckets_keygen() {
  need openssl; _purego_resolve
  local tmp; tmp="$(mktemp)"; chmod 600 "$tmp"
  # shellcheck disable=SC2064
  trap "rm -f '$tmp'" RETURN
  if [[ -f "$S3KEYS" ]]; then
    encrypted "$S3KEYS" || die "$S3KEYS exists but is PLAINTEXT — refusing to touch it."
    sops -d "$S3KEYS" > "$tmp"
  fi
  hdr "buckets keygen -> $S3KEYS"
  local spec name idf secf rest field val changed=0
  for spec in "${S3_KEYS[@]}"; do
    IFS=: read -r name idf secf rest <<<"$spec"
    for field in "$idf" "$secf"; do
      if grep -q "^${field}:" "$tmp"; then
        note "$field already present — kept"
      else
        case "$field" in
          *_id) val="GK$(openssl rand -hex 12)";;
          *)    val="$(openssl rand -hex 32)";;
        esac
        printf '%s: %s\n' "$field" "$val" >> "$tmp"
        ok "minted $field"; changed=1
      fi
    done
  done
  if [[ $changed == 0 ]]; then note "nothing to mint — all keys already present."; return 0; fi
  cp "$tmp" "$S3KEYS"
  sops --config "$SOPS_YAML" -e -i "$S3KEYS"
  encrypted "$S3KEYS" || die "FATAL: $S3KEYS did not encrypt — inspect it NOW (may hold plaintext keys)."
  ok "wrote + encrypted $S3KEYS (workstation-only recipient)."
  warn "Copy these into your password manager AND prod's k8s backup Secret, then apply:"
  note "  fleet buckets apply        # push to the cluster"
  note "  fleet secrets  (choice v)  # stage the ENCRYPTED s3-keys.enc.yaml, then commit"
}

# Push the declared buckets + keys to a live storage node. Idempotent. Secret
# material travels over ssh STDIN (never argv). This is the reprovision path:
# run it after a rebuild to restore identical buckets + credentials cluster-wide.
buckets_apply() {
  need ssh; _purego_resolve
  [[ -f "$S3KEYS" ]] || die "no S3 keys yet — run: fleet buckets keygen"
  local host; host="$(reachable_storage_node)" \
    || die "no storage node reachable with garage up (check: fleet status / fleet unlock <node>)."
  hdr "buckets apply -> $host"

  # Remote reconciler: reads a manifest on stdin (a BUCKETS line + one KEY line per
  # key), runs create/import/allow. garage reads /dev/null so it never eats the loop.
  local remote='set -eu
G() { garage -c /etc/garage.toml "$@" </dev/null; }
while read -r kind body; do
  case "$kind" in
    BUCKETS) for b in $body; do G bucket create "$b" 2>/dev/null || true; echo ">> bucket $b"; done ;;
    KEY)
      # shellcheck disable=SC2086
      set -- $body; name=$1; id=$2; secret=$3; bkts=$4
      if G key info "$id" >/dev/null 2>&1; then echo ">> key $name exists ($id)"
      else G key import --yes -n "$name" "$id" "$secret" >/dev/null; echo ">> imported $name ($id)"; fi
      oldifs=$IFS; IFS=,
      for b in $bkts; do G bucket allow --read --write "$b" --key "$id" >/dev/null; echo ">> allow $name rw $b"; done
      IFS=$oldifs ;;
  esac
done'

  local spec name idf secf bkts id secret
  {
    printf 'BUCKETS %s\n' "${BUCKETS[*]}"
    for spec in "${S3_KEYS[@]}"; do
      IFS=: read -r name idf secf bkts <<<"$spec"
      id="$(s3_get "$idf")"; secret="$(s3_get "$secf")"
      [[ -n "$id" && -n "$secret" ]] || die "missing $idf/$secf in $S3KEYS — run: fleet buckets keygen"
      printf 'KEY %s %s %s %s\n' "$name" "$id" "$secret" "$bkts"
    done
  } | ssh -o BatchMode=yes -o ConnectTimeout=10 "root@$host" "$remote" | sed 's/^/  /'
  ok "buckets applied on $host (cluster-wide state; other nodes gossip it)."
}

# Show live buckets, keys, and per-bucket permissions from a reachable node.
buckets_status() {
  need ssh
  local host; host="$(reachable_storage_node)" \
    || die "no storage node reachable with garage up."
  hdr "buckets status @ $host"
  local remote='set -eu
garage -c /etc/garage.toml bucket list
echo; garage -c /etc/garage.toml key list; echo
for b in '"${BUCKETS[*]}"'; do
  echo "== $b =="
  garage -c /etc/garage.toml bucket info "$b" 2>/dev/null || echo "  (absent)"
done'
  ssh -o BatchMode=yes -o ConnectTimeout=8 "root@$host" "$remote" | sed 's/^/  /'
}

# Read-only object browser for ONE bucket, in your web browser. NO server on the
# cluster: opens an ssh port-forward to the node's garage S3 (tailscale0:3900),
# then runs `rclone serve http` on localhost with a THROWAWAY config built from
# sops. `rclone serve http` is read-only and --read-only makes that explicit, so an
# RW bucket key cannot mutate anything through this UI. The tunnel + config are torn
# down on exit; the secret never touches argv or a persisted file. Per-bucket keys
# mean one key sees one bucket — browse is per-bucket by design (isolation intact).
buckets_browse() {
  local bucket="${1:-}" addr="${2:-127.0.0.1:8080}"
  if [[ -z "$bucket" ]]; then
    note "usage: fleet buckets browse <bucket> [listen-addr]"
    note "buckets: ${BUCKETS[*]}"; return 1
  fi
  local b found=0; for b in "${BUCKETS[@]}"; do [[ "$b" == "$bucket" ]] && found=1; done
  [[ $found == 1 ]] || die "unknown bucket: $bucket (known: ${BUCKETS[*]})"
  need ssh; _purego_resolve
  [[ -f "$S3KEYS" ]] || die "no S3 keys — run: fleet buckets keygen && fleet buckets apply"

  # Which key grants this bucket (from the spec)?
  local spec name idf secf bkts id="" secret="" keyname=""
  for spec in "${S3_KEYS[@]}"; do
    IFS=: read -r name idf secf bkts <<<"$spec"
    case ",$bkts," in
      *",$bucket,"*) keyname="$name"; id="$(s3_get "$idf")"; secret="$(s3_get "$secf")" ;;
    esac
  done
  [[ -n "$id" && -n "$secret" ]] || die "no key for $bucket in the spec/sops — run: fleet buckets keygen."

  # rclone: prefer PATH, else the (unpinned) nixpkgs build — fine for an interactive browser.
  local rc=(rclone)
  have rclone || { note "rclone not on PATH — using nix run nixpkgs#rclone"; rc=(nix run nixpkgs#rclone --); }

  local host; host="$(reachable_storage_node)" || die "no storage node reachable with garage up."
  local tsip; tsip="$(ssh -o BatchMode=yes -o ConnectTimeout=6 "root@$host" 'tailscale ip -4 2>/dev/null | head -1')"
  [[ "$tsip" =~ ^[0-9.]+$ ]] || die "could not read $host's tailscale IP (is tailscale up on it?)."

  hdr "buckets browse — $bucket (key $keyname, READ-ONLY) @ http://$addr"
  local lport=13900 ctl cfg; ctl="$(mktemp -u)"; cfg="$(mktemp)"; chmod 600 "$cfg"
  # shellcheck disable=SC2064
  trap "ssh -S '$ctl' -O exit 'root@$host' 2>/dev/null || true; rm -f '$cfg'" RETURN INT TERM

  note "ssh tunnel 127.0.0.1:$lport -> $host ($tsip:3900)..."
  ssh -o BatchMode=yes -o ExitOnForwardFailure=yes -M -S "$ctl" -f -N \
      -L "127.0.0.1:$lport:$tsip:3900" "root@$host" \
    || die "ssh tunnel failed (local port $lport busy? close any other browse session)."

  cat >"$cfg" <<CFG
[garage]
type = s3
provider = Other
access_key_id = $id
secret_access_key = $secret
endpoint = http://127.0.0.1:$lport
region = garage
force_path_style = true
CFG

  ok "open http://$addr in your browser. Ctrl-C here to stop + tear down."
  "${rc[@]}" serve http "garage:$bucket" --config "$cfg" --addr "$addr" --read-only || true
}

# ============================================================================= layout
# Garage cluster LAYOUT (zone + capacity per node) is imperative, versioned cluster
# state — it CANNOT live in garage.toml. This drives it from the DECLARATIVE spec in
# each host's .nix (fleet.zone + fleet.garageCapacity): assign every storage node its
# role, then apply as version+1. Run once, or whenever the topology changes. The
# apply needs cluster QUORUM, so every node already in the layout must be up.
cmd_layout() {
  case "${1:-}" in
    show)  shift; layout_show  "$@";;
    apply) shift; layout_apply "$@";;
    ""|-h|--help) note "usage: fleet layout <show|apply>";;
    *) die "unknown layout subcommand: $1 (show|apply)";;
  esac
}

layout_show() {
  need ssh
  local host; host="$(reachable_storage_node)" || die "no storage node reachable with garage up."
  hdr "garage layout @ $host"
  ssh -o BatchMode=yes -o ConnectTimeout=8 "root@$host" \
    'garage -c /etc/garage.toml layout show' 2>&1 | sed 's/^/  /'
}

# Assign each storage node from its .nix (fleet.zone + fleet.garageCapacity), then
# apply version+1. Node ids are fetched LIVE (they are runtime state, not in Nix).
# Idempotent: re-assigning an unchanged role stages nothing, so apply is skipped
# when there are no staged changes.
layout_apply() {
  need ssh; require_nix layout
  tailnet_set || die "set the tailnet first: fleet config tailnet <name>"
  local host; host="$(reachable_storage_node)" || die "no storage node reachable with garage up."
  hdr "layout apply (spec from each host's fleet.zone + fleet.garageCapacity)"

  local node zone cap nid staged=0
  for node in node-a node-b node-c; do
    { [[ -f "$HOSTS/$node.nix" ]] && flake_has_node "$node"; } || continue
    cap="$(nix eval --raw ".#nixosConfigurations.$node.config.fleet.garageCapacity" 2>/dev/null || true)"
    [[ -n "$cap" && "$cap" != "null" ]] || { note "$node: no fleet.garageCapacity — skipping (not a storage member)."; continue; }
    zone="$(nix eval --raw ".#nixosConfigurations.$node.config.fleet.zone" 2>/dev/null || true)"
    [[ -n "$zone" && "$zone" != "null" ]] || { warn "$node: fleet.zone unset — skipping."; continue; }
    nid="$(ssh -o BatchMode=yes -o ConnectTimeout=6 "root@$(deploy_host "$node")" \
             'garage -c /etc/garage.toml node id -q 2>/dev/null' | cut -d@ -f1)"
    [[ -n "$nid" ]] || { warn "$node: unreachable / garage down — cannot fetch node id (apply needs ALL nodes up)."; continue; }
    note "assign $node  id=$nid  zone=$zone  cap=$cap"
    ssh -o BatchMode=yes -o ConnectTimeout=8 "root@$host" \
      "garage -c /etc/garage.toml layout assign $nid -z $zone -c $cap" 2>&1 | sed 's/^/    /'
    staged=1
  done
  [[ $staged == 1 ]] || { note "nothing to assign."; return; }

  # Re-assigning identical roles stages nothing — only apply if garage staged a change.
  if ! ssh -o BatchMode=yes -o ConnectTimeout=8 "root@$host" \
        'garage -c /etc/garage.toml layout show' 2>/dev/null | grep -qi 'staged'; then
    ok "no layout changes to apply (roles already current)."
    return
  fi
  local ver next
  ver="$(ssh -o BatchMode=yes -o ConnectTimeout=8 "root@$host" \
          'garage -c /etc/garage.toml layout show' 2>/dev/null | grep -oiP 'layout version: \K[0-9]+')"
  next=$((ver + 1))
  warn "apply as version $next — needs cluster QUORUM (every node in the layout must be up)."
  confirm "apply layout v$next now?" || { note "staged, NOT applied. Later: garage layout apply --version $next"; return; }
  ssh -o BatchMode=yes -o ConnectTimeout=10 "root@$host" \
    "garage -c /etc/garage.toml layout apply --version $next" 2>&1 | sed 's/^/  /'
  ok "layout applied (v$next)."
}

# ============================================================================= secrets
cmd_secrets() {
  while :; do
    hdr "secrets"
    shopt -s nullglob; local files=("$SECRETS"/*.enc.yaml); shopt -u nullglob
    local i=1
    for f in "${files[@]}"; do
      if encrypted "$f"; then printf '  %2d) %s  %s✔enc%s\n' "$i" "$(basename "$f")" "$G" "$R"
      else printf '  %2d) %s  %sPLAINTEXT%s\n' "$i" "$(basename "$f")" "$RED" "$R"; fi
      i=$((i+1))
    done
    printf '\n  e <n>  edit (sops)   v  verify + git add   r  re-encrypt all   q  back\n'
    local choice; choice="$(ask 'choice')"
    case "$choice" in
      e*) local n="${choice#e }"; n="${n// /}"; [[ "$n" =~ ^[0-9]+$ ]] && sops "${files[$((n-1))]}" || warn "give an index, e.g. 'e 1'";;
      v)  local bad; bad="$(grep -L '^sops:' "$SECRETS"/*.enc.yaml 2>/dev/null || true)"
          if [[ -n "$bad" ]]; then err "PLAINTEXT files — NOT staging:"; printf '   %s\n' $bad
          else git -C "$ROOT" add .sops.yaml "$SECRETS"/*.enc.yaml flake.nix hosts/ 2>/dev/null
               ok "staged .sops.yaml + encrypted secrets + flake/hosts"; git -C "$ROOT" status --short | sed 's/^/   /'
               note "now: git commit -m 'fleet: add/update node secrets'"; fi;;
      r)  for f in "${files[@]}"; do sops --config "$SOPS_YAML" updatekeys -y "$f" >/dev/null && ok "updatekeys $(basename "$f")"; done;;
      q|"") return;;
      *) warn "unknown choice";;
    esac
    pause
  done
}

# Gitignored, NON-regenerable key material = the exact set to keep OFFLINE in the
# password manager. The devcontainer workstation is disposable — a rebuild wipes
# private-keys/ — so this warns when any file is missing, catching a HALF-RESTORED
# workstation before an install/deploy. Returns nonzero if anything is missing.
vault_check() {
  local nodes=("$@") miss=0 node p base
  hdr "vault — gitignored keys to keep in the password manager"
  base="$(basename "$FLEET_AGE_KEY_FILE")"
  if [[ -f "$FLEET_AGE_KEY_FILE" ]]; then
    printf '  %s %-18s %s\n' "$(mk ok)" "$base" 'fleet age key — decrypts ALL node secrets'
  else
    printf '  %s %-18s %s\n' "$(mk no)" "$base" 'MISSING — restore from password manager'; miss=1
  fi
  for node in "${nodes[@]}"; do
    p="$(node_age_key_path "$node")"
    if [[ -f "$p" ]]; then
      printf '  %s %-18s %s\n' "$(mk ok)" "$(basename "$p")" "$node identity (seeded at install)"
    else
      printf '  %s %-18s %s\n' "$(mk no)" "$(basename "$p")" "MISSING — restore from password manager"; miss=1
    fi
  done
  if [[ $miss == 1 ]]; then
    warn "vault INCOMPLETE — this workstation is half-restored. Paste the missing"
    warn "file(s) into private-keys/ (chmod 600) BEFORE any install/deploy."
  fi
  note "Also vault (not files): ZFS passphrases (A dpool + A LUKS-recovery + B + C) and per-node root passwords."
  return "$miss"
}

# ============================================================================= status
cmd_status() {
  local nodes=()
  if [[ $# -ge 1 ]]; then nodes=("$(canon "$1")"); else
    shopt -s nullglob; for f in "$HOSTS"/node-*.nix; do
      [[ "$(basename "$f")" == disko-* || "$(basename "$f")" == *-hardware.nix ]] && continue
      nodes+=("$(basename "${f%.nix}")"); done; shopt -u nullglob
  fi
  hdr "fleet status"

  # --- workstation-side readiness (label-aligned; glyph then free text) -------
  printf '  %-16s %s  %s\n' 'fleet age key' \
    "$([[ -f "$FLEET_AGE_KEY_FILE" ]] && mk ok || mk no)" \
    "$([[ -f "$FLEET_AGE_KEY_FILE" ]] && printf '%s' "$FLEET_AGE_KEY_FILE" || printf 'missing')"
  printf '  %-16s %s\n'     '.sops recipients' "$(recipient_set && mk ok || mk no)"
  printf '  %-16s %s  %s\n' 'common secret' \
    "$(encrypted "$COMMON" && mk ok || mk no)" \
    "$(encrypted "$COMMON" && printf 'encrypted' || printf 'NOT encrypted')"
  printf '  %-16s %s  %s\n' 'tailnet' \
    "$(tailnet_set && mk ok || mk no)" \
    "$(tailnet_set && grep -oP 'tailnet = "\K[^"]+' "$FLAKE" | head -1 || printf '<unset>')"

  vault_check "${nodes[@]}" || true

  # --- per-node table. Each status column is 9 cells: a header "  %-7s" (2+7) and
  # a data cell "  <glyph>      " (2 + 1 glyph + 6 spaces). The glyph is one display
  # cell (mk), so headers and glyphs line up exactly. Prefix = 2+8+1+21 = 32. -----
  local rule; rule="$(printf '─%.0s' $(seq 1 95))"
  printf '\n  %s%-8s %-21s%s' "$B" 'NODE' 'ROLE' "$R"
  local h; for h in agekey recip authkey commit install deploy garage; do printf '  %s%-7s%s' "$B" "$h" "$R"; done; printf '\n'
  printf '  %s%s%s\n' "$D" "$rule" "$R"

  # `garage` is a LIVE probe. Kick one off per installed node in the background so
  # the whole fleet is checked in parallel (offline nodes cost one timeout, not N);
  # non-installed nodes get 'na' with no ssh. Results land in $gdir/<node>.
  local gdir node; gdir="$(mktemp -d)"
  for node in "${nodes[@]}"; do
    if [[ -f "$STATE_DIR/installed-$node" ]]; then
      probe_garage "$node" >"$gdir/$node" &
      probe_tsip   "$node" >"$gdir/$node.tsip" &
    else
      echo na >"$gdir/$node"
    fi
  done
  wait

  local type ts
  for node in "${nodes[@]}"; do
    type="$(type_of "$node" 2>/dev/null || echo '?')"; ts="$SECRETS/$node.enc.yaml"
    printf '  %-8s %-21s' "$node" "$(type_short "$type")"
    printf '  %s      ' "$([[ -f "$(node_age_key_path "$node")" ]] && mk ok || mk no)"
    printf '  %s      ' "$(node_recipient_ready "$node" && mk ok || mk no)"
    printf '  %s      ' "$(encrypted "$ts" && mk ok || mk no)"
    printf '  %s      ' "$(committed "hosts/$node.nix" && mk ok || mk no)"
    printf '  %s      ' "$([[ -f "$STATE_DIR/installed-$node" ]] && mk ok || mk na)"
    printf '  %s      ' "$([[ -f "$STATE_DIR/deployed-$node" ]] && mk ok || mk na)"
    printf '  %s      ' "$(mk "$(cat "$gdir/$node" 2>/dev/null || echo na)")"
    printf '\n'
  done

  # --- tailnet addresses: each node's live tailscale0 IP (falls back to the
  # declared fleet.tailscaleIp) + its MagicDNS name. Handy for ssh / S3 endpoints.
  if tailnet_set; then
    local live decl magic show src
    printf '\n  %s%-8s %-17s %-28s %s%s\n' "$B" 'NODE' 'TAILSCALE IP' 'MAGICDNS' 'SRC' "$R"
    for node in "${nodes[@]}"; do
      live="$(cat "$gdir/$node.tsip" 2>/dev/null || true)"
      decl="$(grep -oP 'tailscaleIp = "\K[^"]+' "$HOSTS/$node.nix" 2>/dev/null | head -1)"
      magic="$(deploy_host "$node")"
      if   [[ -n "$live" ]]; then show="$live"; src="${G}live${R}"
      elif [[ -n "$decl" ]]; then show="$decl"; src="${D}declared${R}"
      else show='-'; src="${D}-${R}"; fi
      printf '  %-8s %-17s %-28s %b\n' "$node" "$show" "$magic" "$src"
    done
  fi
  rm -rf "$gdir"
  printf '  %s%s  %s✓%s ready  %s✗%s missing  %s·%s not-yet%s\n' \
    "$D" 'legend:' "$G" "$D" "$RED" "$D" "$D" "$D" "$R"
  printf '  %s%s  garage = LIVE ssh probe: %s✓%s active  %s✗%s down  %s·%s unreachable/not-installed%s\n' \
    "$D" '       ' "$G" "$D" "$RED" "$D" "$D" "$D" "$R"
}

# ============================================================================= guide
cmd_guide() {
  local node; node="$(canon "${1:-node-a}")"; local type; type="$(type_of "$node" 2>/dev/null || echo '?')"
  hdr "on-box fallback runbook — $node (full: documentations/04-node-a-b-install.md)"
  cat <<EOF
  Preferred path is remote:   fleet install $node root@<installer-ip>
  Console/USB fallback (no network install):
    1. Write the NixOS 25.05 minimal ISO to USB; boot $node; 'sudo -i'.
    2. lsblk  — confirm disks vs hosts/disko-$node.nix; copy the repo to /root/garage-fleet.
    3. nix run .#disko -- --mode destroy,format,mount --flake .#$node --yes-wipe-all-disks
       (type the ZFS passphrase at the prompt — keylocation=prompt by default)
    4. seed the node age key (the ONLY required seed — NOT the SSH host key, sshd
       self-generates that): install -d -m700 /mnt/var/lib/sops-nix
       install -m400 private-keys/$node-age.txt /mnt/var/lib/sops-nix/key.txt
       nixos-install --flake .#$node --no-root-passwd ; reboot
    5. first boot: tailscale status -> set fleet.tailscaleIp ; nixos-rebuild switch --flake .#$node
       sudo zfs load-key -a && sudo zfs mount -a && sudo systemctl start garage
  Garage layout (ONCE, version = prev+1):
    ID=\$(sudo garage node id -q | cut -d@ -f1)
    sudo garage layout assign "\$ID" -z <zone> -c <bytes> && sudo garage layout apply --version <prev+1>
EOF
}

# ============================================================================= templates
host_template_A() { cat <<'EOF'
# hosts/@NODE@.nix — TYPE A: onsite storage + devcontainer workstation. Scaffolded
# by scripts/fleet. NVMe wpool = UNENCRYPTED dev pool; HDD dpool = encrypted,
# prompt-unlock, all of Garage (the moat).
{ ... }:
{
  imports = [
    ./disko-@NODE@.nix
    ./@NODE@-hardware.nix
    ../modules/zfs-sanoid.nix
    ../modules/workstation.nix
  ];

  networking.hostName = "@NODE@";
  networking.hostId = "@HOSTID@"; # unique 8-hex (auto-generated)

  boot.zfs.extraPools = [ "wpool" "dpool" ];
  boot.zfs.requestEncryptionCredentials = false;

  fleet = {
    role = "storage";
    zone = "@ZONE@";
    proxyNode = false;
    zfsAutoUnlock = false;
    tailscaleIp = "@TSIP@"; # TODO operator: set after first tailscale join
    dataDirs = [ { path = "/srv/garage/data-hdd"; capacity = "900G"; } ]; # TODO capacity
    sanoidDatasets = [ "dpool/garage" ];
  };

}
EOF
}
host_template_BC() { cat <<'EOF'
# hosts/@NODE@.nix — TYPE B/C: offsite storage + Tailscale proxy. Scaffolded by
# scripts/fleet. NVMe npool + HDD dpool, both encrypted prompt-unlock.
{ ... }:
{
  imports = [
    ./disko-@NODE@.nix
    ./@NODE@-hardware.nix
    ../modules/zfs-sanoid.nix
  ];

  networking.hostName = "@NODE@";
  networking.hostId = "@HOSTID@"; # unique 8-hex (auto-generated)

  boot.zfs.extraPools = [ "npool" "dpool" ];
  boot.zfs.requestEncryptionCredentials = false;

  fleet = {
    role = "storage";
    zone = "@ZONE@";
    proxyNode = true;
    zfsAutoUnlock = false;
    tailscaleIp = "@TSIP@"; # TODO operator: set after first tailscale join
    advertiseRoutes = [ ]; # TODO operator: scraper-egress subnet(s), approve in ACL
    dataDirs = [
      { path = "/srv/garage/data-ssd"; capacity = "400G"; } # TODO capacity
      { path = "/srv/garage/data-hdd"; capacity = "900G"; } # TODO capacity
    ];
    sanoidDatasets = [ "npool/garage" "dpool/garage" ];
  };

}
EOF
}
host_template_D() { cat <<'EOF'
