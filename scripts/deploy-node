#!/usr/bin/env bash
# scripts/deploy-node — automate the WORKSTATION side of deploying a garage-fleet
# node. Three jobs:
#   check  <a|b|c|d>          readiness preflight (NO nix needed — runs in the devcontainer)
#   stage  <a|b|c|d> <dest>   write the install payload (repo + node host key) to a USB/dir
#   deploy <a|b|c|d>          post-install update via deploy-rs (needs nix + node reachable)
#   guide  <a|b|c|d>          print the on-box live-USB install steps
#
# The FIRST install of a node is the interactive on-box runbook (disko →
# nixos-install → unlock → garage layout); see `guide` and documentations/13.
# deploy-rs only works AFTER that first generation exists (magic-rollback needs a
# baseline). This script complements scripts/bootstrap-node (the secret-prep TUI),
# which unlike this one requires nix.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SECRETS="$ROOT/secrets"
SOPS_YAML="$ROOT/.sops.yaml"
# Fleet age key: prefer the in-repo private-keys/ copy, else the sops default path.
FLEET_AGE_KEY_FILE="${FLEET_AGE_KEY_FILE:-$ROOT/private-keys/garage-fleet.txt}"
[[ -f "$FLEET_AGE_KEY_FILE" ]] || FLEET_AGE_KEY_FILE="${HOME}/.config/sops/age/garage-fleet.txt"
export SOPS_AGE_KEY_FILE="$FLEET_AGE_KEY_FILE"

if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
  B=$'\e[1m'; R=$'\e[0m'; GRN=$'\e[32m'; YEL=$'\e[33m'; RED=$'\e[31m'; CYA=$'\e[36m'
else B=""; R=""; GRN=""; YEL=""; RED=""; CYA=""; fi
ok()   { printf '%s✔%s %s\n' "$GRN" "$R" "$1"; }
warn() { printf '%s⚠%s  %s\n' "$YEL" "$R" "$1"; WARN=$((WARN+1)); }
err()  { printf '%s✗%s %s\n' "$RED" "$R" "$1" >&2; FAIL=$((FAIL+1)); }
note() { printf '%s•%s %s\n' "$CYA" "$R" "$1"; }
hdr()  { echo; printf '%s== %s ==%s\n' "$B" "$1" "$R"; }

usage() { sed -n '2,9p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'; exit "${1:-0}"; }

letter() { # validate + echo a node letter
  local l="${1:-}"; l="${l#node-}"; l="${l,,}"
  [[ "$l" =~ ^[abcd]$ ]] || { err "node must be a|b|c|d (got '${1:-}')"; exit 2; }
  echo "$l"
}

encrypted() { [[ -f "$1" ]] && grep -q '^sops:' "$1"; }
uncommented_keys() { grep -cE '^[[:space:]]*"ssh-(ed25519|rsa|ecdsa)' "$1" 2>/dev/null || echo 0; }

cmd_check() {
  local l; l="$(letter "${1:-}")"; local node="node-$l"
  FAIL=0; WARN=0
  hdr "preflight: $node"

  # repo sanity
  [[ -f "$SOPS_YAML" && -f "$ROOT/flake.nix" ]] && ok "repo root ok ($ROOT)" || err "not a garage-fleet repo root"

  # login SSH keys (NixOS refuses to build with none)
  local nk; nk="$(uncommented_keys "$ROOT/modules/base.nix")"
  (( nk >= 1 )) && ok "base.nix has $nk SSH login key(s) (ops/root)" || err "base.nix: NO uncommented SSH key — build will fail (§0.2)"
  if [[ "$l" == a ]]; then
    local dk; dk="$(uncommented_keys "$ROOT/modules/workstation.nix")"
    (( dk >= 1 )) && ok "workstation.nix has a dev SSH key (DevPod)" || warn "workstation.nix: no dev SSH key — DevPod can't log in"
  fi

  # secrets present + encrypted
  encrypted "$SECRETS/common.sops.yaml" && ok "common.sops.yaml encrypted" || err "common.sops.yaml missing/plaintext"
  local ts="$SECRETS/${node}-tailscale.sops.yaml"
  encrypted "$ts" && ok "${node}-tailscale.sops.yaml encrypted" || err "${node}-tailscale.sops.yaml missing/plaintext"

  # node recipient wired into .sops.yaml
  grep -qE "^[[:space:]]*-[[:space:]]*&node_${l}[[:space:]]+age1" "$SOPS_YAML" \
    && ok "${node} recipient present in .sops.yaml" \
    || err "${node} recipient still commented in .sops.yaml (bootstrap-node menu 2)"

  # can the fleet key actually decrypt? (catches stale updatekeys)
  if [[ -f "$FLEET_AGE_KEY_FILE" ]]; then
    sops -d "$SECRETS/common.sops.yaml" >/dev/null 2>&1 && ok "common decrypts with fleet key" || err "common does NOT decrypt (SOPS_AGE_KEY_FILE=$FLEET_AGE_KEY_FILE)"
  else
    warn "fleet age key not found ($FLEET_AGE_KEY_FILE) — skipped decrypt check"
  fi

  # node SSH host key (its sops identity, seeded at install)
  [[ -f "$ROOT/${node}-extra/etc/ssh/ssh_host_ed25519_key" ]] \
    && ok "${node}-extra host key present" \
    || err "${node}-extra/etc/ssh/ssh_host_ed25519_key missing (bootstrap-node menu 2)"

  # per-host placeholders (soft)
  local hf="$ROOT/hosts/${node}.nix"
  if [[ -f "$hf" ]]; then
    grep -qE 'hostId = "[0-9a-f]{8}"' "$hf" && ok "hostId set" || warn "hostId not an 8-hex value in ${node}.nix"
    grep -q 'capacity =' "$hf" && ok "dataDirs capacity set" || warn "no dataDirs capacity in ${node}.nix"
  else err "hosts/${node}.nix missing"; fi
  note "confirm disko device paths with \`lsblk\` ON THE BOX before formatting"

  # committed? (flake copies only git-tracked files)
  if git -C "$ROOT" ls-files --error-unmatch "secrets/${node}-tailscale.sops.yaml" >/dev/null 2>&1; then
    ok "${node} secrets are git-tracked (flake will see them)"
  else
    warn "${node} secrets NOT committed — commit before building the payload USB"
  fi

  command -v nix >/dev/null 2>&1 && ok "nix present (flake check / deploy available)" \
    || note "nix absent here — run flake check / disko / nixos-install on the box or a nix host"

  echo
  if (( FAIL )); then err "$FAIL blocker(s), $WARN warning(s) — NOT ready to install $node"; exit 1
  else ok "$node ready to stage/install ($WARN warning(s))"; fi
}

cmd_stage() {
  local l; l="$(letter "${1:-}")"; local node="node-$l"
  local dest="${2:-}"; [[ -n "$dest" ]] || { err "usage: deploy-node stage $l <dest-dir-or-USB-mount>"; exit 2; }
  [[ -d "$dest" ]] || { err "dest '$dest' is not a directory (mount the USB first)"; exit 2; }
  local out="$dest/garage-fleet"
  hdr "stage payload for $node → $out"
  # git archive = ONLY committed (encrypted) files — an uncommitted plaintext
  # secret can never leak onto the USB this way.
  rm -rf "$out"; mkdir -p "$out"
  git -C "$ROOT" archive --format=tar HEAD | tar -x -C "$out"
  ok "copied git-tracked repo (no .git, no uncommitted files)"
  # the node's own host key is gitignored — copy it explicitly (it is that node's
  # sops identity; seeded into /etc/ssh at install). NEVER copy private-keys/.
  install -d -m700 "$out/${node}-extra/etc/ssh"
  cp "$ROOT/${node}-extra/etc/ssh/ssh_host_ed25519_key"     "$out/${node}-extra/etc/ssh/"
  cp "$ROOT/${node}-extra/etc/ssh/ssh_host_ed25519_key.pub" "$out/${node}-extra/etc/ssh/"
  chmod 600 "$out/${node}-extra/etc/ssh/ssh_host_ed25519_key"
  ok "copied ${node}-extra host key"
  note "did NOT copy private-keys/ (the fleet age key never goes on a node)"
  ok "payload ready. Boot ${node} from the NixOS installer USB, then: deploy-node guide $l"
}

cmd_deploy() {
  local l; l="$(letter "${1:-}")"; local node="node-$l"
  command -v nix >/dev/null 2>&1 || { err "deploy-rs needs nix — not available here"; exit 1; }
  hdr "deploy-rs → $node (post-install update)"
  warn "deploy-rs is for nodes ALREADY installed. The FIRST install is on-box (guide $l)."
  warn "First post-install push has no magic-rollback baseline — keep console reachable."
  note "targetHost comes from flake.nix deploy map (set the <tailnet> placeholder first)."
  ( cd "$ROOT" && nix run github:serokell/deploy-rs -- ".#${node}" "${@:2}" )
}

cmd_guide() {
  local l; l="$(letter "${1:-}")"; local node="node-$l" zone ver
  if [[ "$l" == a ]]; then zone=onsite ver=1; elif [[ "$l" == b ]]; then zone=offsite-1 ver=2; else zone="?" ver="?"; fi
  hdr "on-box live-USB install — $node  (full runbook: documentations/13)"
  cat <<EOF
1. Build USBs (workstation):
   curl -L -o nixos.iso https://channels.nixos.org/nixos-25.05/latest-nixos-minimal-x86_64-linux.iso
   lsblk; sudo dd if=nixos.iso of=/dev/sdX bs=4M conv=fsync status=progress     # sdX = the USB
   scripts/deploy-node stage $l /media/USB                                       # payload onto a 2nd USB

2. Boot $node from the installer USB, then as root:
   sudo -i; ping -c1 nixos.org; lsblk            # CONFIRM disks vs hosts/disko-${node}.nix
   mkdir -p /mnt-usb && mount /dev/sdY1 /mnt-usb && cp -r /mnt-usb/garage-fleet /root/garage-fleet
   export NIX_CONFIG="experimental-features = nix-command flakes"
   cd /root/garage-fleet && { [ -f flake.lock ] || nix flake lock; }

3. Format + install:
   nix run github:nix-community/disko -- --mode destroy,format,mount --flake .#${node} --yes-wipe-all-disks
$( [[ "$l" == a ]] && echo "   # node-A: ONE passphrase prompt (dpool/garage); wpool is unencrypted" \
                   || echo "   # TWO passphrase prompts (npool + dpool), same passphrase" )
   install -d -m700 /mnt/etc/ssh
   cp /mnt-usb/garage-fleet/${node}-extra/etc/ssh/ssh_host_ed25519_key{,.pub} /mnt/etc/ssh/
   chmod 600 /mnt/etc/ssh/ssh_host_ed25519_key
   nixos-install --flake /root/garage-fleet#${node} --no-root-passwd
   umount -R /mnt && zpool export -a && reboot   # pull the installer USB

4. First boot — set the real overlay IP, unlock, start Garage:
   tailscale status                              # note ${node}'s 100.x.y.z
   # edit hosts/${node}.nix: fleet.tailscaleIp = "100.x.y.z"$( [[ "$l" == b ]] && echo "  (+ advertiseRoutes)" )
   sudo nixos-rebuild switch --flake /root/garage-fleet#${node}
   sudo zfs load-key -a && sudo zfs mount -a && sudo systemctl start garage

5. Layout (zone ${zone}, version ${ver} — exactly prev+1, ONCE):
   export GARAGE="sudo garage"; ID=\$(\$GARAGE node id -q | cut -d@ -f1)
   \$GARAGE layout assign "\$ID" -z ${zone} -c <bytes> && \$GARAGE layout apply --version ${ver}
EOF
  [[ "$l" == a ]] && cat <<EOF

6. node-A workstation check (dual-role): sudo -u dev podman info | grep graphDriver
   From your Mac: devpod up <repo> --provider ssh   (HOST=dev@${node}.<tailnet>.ts.net)
EOF
}

case "${1:-}" in
  check)  shift; cmd_check  "$@";;
  stage)  shift; cmd_stage  "$@";;
  deploy) shift; cmd_deploy "$@";;
  guide)  shift; cmd_guide  "$@";;
  -h|--help|help|"") usage 0;;
  *) err "unknown command: $1"; usage 2;;
esac
