#!/usr/bin/env bash
# scripts/bootstrap-node — interactive (plain-bash TUI) bootstrap for the
# garage-fleet nodes. Automates the WORKSTATION-side, age/sops secret + flake
# prep that can be scripted, and PRINTS the complete guide for the manual steps
# that cannot (Tailscale admin console, physical USB boot, on-box disko/install/
# unlock/layout, break-glass custody). Full runbook: documentations/13-node-a-b-install.md
#
# Secrets model: sops + age. The repo's secrets ARE age-encrypted — sops encrypts
# each secrets/*.sops.yaml to age recipients (the fleet workstation key + each
# node's ssh-to-age identity). Those encrypted files are committed & pushed; the
# nodes decrypt them via sops-nix. This script owns that workflow end to end.
#
# Runs on a workstation with: bash, sops, age, age-keygen, openssl, ssh-keygen,
# git, nix (flakes). ssh-to-age is used via `nix run nixpkgs#ssh-to-age` if no
# local binary is present. NO secrets are echoed to the terminal.
set -euo pipefail

# --- locations ---------------------------------------------------------------
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SECRETS="${ROOT}/secrets"
SOPS_YAML="${ROOT}/.sops.yaml"
COMMON="${SECRETS}/common.sops.yaml"
FLEET_AGE_KEY_FILE="${FLEET_AGE_KEY_FILE:-${HOME}/.config/sops/age/garage-fleet.txt}"
export SOPS_AGE_KEY_FILE="${FLEET_AGE_KEY_FILE}"

# --- pretty (degrade to plain on non-tty / NO_COLOR) -------------------------
if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
  B=$'\e[1m'; DIM=$'\e[2m'; R=$'\e[0m'; GRN=$'\e[32m'; YEL=$'\e[33m'; RED=$'\e[31m'; CYA=$'\e[36m'
else B=""; DIM=""; R=""; GRN=""; YEL=""; RED=""; CYA=""; fi
rule()    { printf '%s\n' "${DIM}────────────────────────────────────────────────────────────${R}"; }
section() { echo; rule; printf '%s%s%s\n' "$B" "$1" "$R"; rule; }
ok()      { printf '%s✔%s %s\n' "$GRN" "$R" "$1"; }
warn()    { printf '%s⚠%s  %s\n' "$YEL" "$R" "$1"; }
err()     { printf '%s✗%s %s\n' "$RED" "$R" "$1" >&2; }
note()    { printf '%s•%s %s\n' "$CYA" "$R" "$1"; }
pause()   { read -rsp $'\n'"${DIM}Press Enter to continue…${R}" _ || true; echo; }
ask()     { local p="$1" d="${2:-}" a; read -rp "$p${d:+ [$d]}: " a || true; echo "${a:-$d}"; }
confirm() { local a; read -rp "$1 [y/N]: " a || true; [[ "$a" =~ ^[Yy]$ ]]; }

# --- preflight ---------------------------------------------------------------
need() { command -v "$1" >/dev/null 2>&1 || { err "missing required tool: $1"; MISSING=1; }; }
preflight() {
  MISSING=0
  for t in bash sops age age-keygen openssl ssh-keygen git nix; do need "$t"; done
  [[ -f "$SOPS_YAML" ]] || { err "no .sops.yaml at repo root ($ROOT) — wrong directory?"; MISSING=1; }
  [[ "$MISSING" -eq 0 ]] || { err "fix the above and re-run."; exit 1; }
}

# ssh-to-age: local binary if present, else nix run (first call may fetch).
ssh_to_age() {
  if command -v ssh-to-age >/dev/null 2>&1; then ssh-to-age "$@"
  else nix run nixpkgs#ssh-to-age -- "$@"; fi
}

# --- status ------------------------------------------------------------------
fleet_recipient() { age-keygen -y "$FLEET_AGE_KEY_FILE" 2>/dev/null; }
recipient_set()   { ! grep -q 'age1FLEET_PLACEHOLDER_REPLACE_ME' "$SOPS_YAML"; }
encrypted()       { [[ -f "$1" ]] && grep -q '^sops:' "$1" 2>/dev/null; }
node_prepared()   { grep -qE "^[[:space:]]*-[[:space:]]*&node_$1[[:space:]]+age1" "$SOPS_YAML"; }

status() {
  section "garage-fleet bootstrap — status"
  printf '  repo            %s\n' "$ROOT"
  printf '  fleet age key   '; [[ -f "$FLEET_AGE_KEY_FILE" ]] && ok "$FLEET_AGE_KEY_FILE" || warn "not generated"
  printf '  .sops recipient '; recipient_set && ok "set" || warn "still placeholder (run 1)"
  printf '  common secrets  '; encrypted "$COMMON" && ok "encrypted" || warn "not created (run 1)"
  local l
  for l in a b; do
    printf '  node-%s          ' "$l"
    if node_prepared "$l" && [[ -f "${SECRETS}/node-${l}-tailscale.sops.yaml" ]]; then ok "recipient + authkey ready"
    else warn "not prepared (run 2)"; fi
  done
}

# --- 1. fleet secrets --------------------------------------------------------
ensure_fleet_key() {
  if [[ -f "$FLEET_AGE_KEY_FILE" ]]; then ok "fleet age key exists: $FLEET_AGE_KEY_FILE"
  else
    note "generating fleet age keypair → $FLEET_AGE_KEY_FILE"
    mkdir -p "$(dirname "$FLEET_AGE_KEY_FILE")"
    ( umask 077; age-keygen -o "$FLEET_AGE_KEY_FILE" >/dev/null 2>&1 )
    ok "generated."
    warn "BREAK-GLASS: copy this PRIVATE key offline to TWO physical locations."
    warn "Losing it makes every fleet secret an unreadable brick (doc 09 §8)."
  fi
  local recip; recip="$(fleet_recipient)"
  note "fleet recipient (public): ${B}${recip}${R}"
  if ! recipient_set; then
    sed -i "s|age1FLEET_PLACEHOLDER_REPLACE_ME|${recip}|" "$SOPS_YAML"
    ok "wrote fleet recipient into .sops.yaml"
  else ok ".sops.yaml recipient already set"; fi
}

init_fleet_secrets() {
  section "1. Fleet secrets (run ONCE for the whole fleet)"
  ensure_fleet_key
  echo
  if encrypted "$COMMON"; then
    warn "secrets/common.sops.yaml already exists (encrypted)."
    confirm "Rotate rpc/admin/metrics tokens (forces garage restart on next deploy)?" || { note "kept existing."; return; }
  fi
  note "generating rpc_secret / admin_token / metrics_token (NOT echoed)…"
  # Prompt-unlock fleet (doc 13): NO zfs-passphrase here — the ZFS key is typed at
  # disko format on the box and never stored. Only these three live in sops.
  umask 077
  {
    printf 'rpc_secret: "%s"\n'    "$(openssl rand -hex 32)"
    printf 'admin_token: "%s"\n'   "$(openssl rand -hex 32)"
    printf 'metrics_token: "%s"\n' "$(openssl rand -hex 32)"
  } > "$COMMON"
  sops --config "$SOPS_YAML" -e -i "$COMMON"
  if encrypted "$COMMON"; then ok "secrets/common.sops.yaml encrypted."; else err "encryption failed"; return 1; fi
  echo
  warn "MANUAL — Tailscale admin console (cannot be scripted):"
  cat <<EOF
   • Mint a REUSABLE, NON-EPHEMERAL, tag:garage auth key per node (paste it in
     step 2). https://login.tailscale.com/admin/settings/keys
   • ACL (deny-by-default, doc 09 §3):
       tag:garage → tag:garage   on tcp:3900,3901,3903
       tag:k8s    → tag:garage   on tcp:3900 ONLY   (never 3901/3903)
     Pre-approve node-B's advertised subnet route / exit-node.
EOF
}

# --- 2. prepare a node -------------------------------------------------------
sops_add_node() { # $1=letter (a/b/c/d)  $2=recipient
  local l="$1" recip="$2" up="${1^^}"
  # uncomment + fill the &node_X anchor (unique placeholder token)
  sed -i "s|#- &node_${l} age1NODE${up}_PLACEHOLDER_REPLACE_ME|- \&node_${l} ${recip}|" "$SOPS_YAML"
  # uncomment every `#- *node_X` reference (the common rule + this node's tailscale rule)
  sed -i "s|#- \*node_${l}|- *node_${l}|g" "$SOPS_YAML"
}

prepare_node() {
  section "2. Prepare a node (workstation side)"
  encrypted "$COMMON" || { warn "Run step 1 (fleet secrets) first."; return; }
  local l; l="$(ask 'Which node to prepare? (a/b/c/d)')"; l="${l,,}"
  [[ "$l" =~ ^[abcd]$ ]] || { err "expected a, b, c or d."; return; }
  local node="node-${l}" extra="${ROOT}/node-${l}-extra"
  local hk="${extra}/etc/ssh/ssh_host_ed25519_key"
  local tsfile="${SECRETS}/node-${l}-tailscale.sops.yaml"

  # 2a. SSH host key = the node's sops/age identity (seeded onto the box at install)
  if [[ -f "$hk" ]]; then ok "host key exists: ${hk}"
  else
    note "generating ${node} SSH host key (its sops/age identity)…"
    install -d -m700 "${extra}/etc/ssh"
    ssh-keygen -t ed25519 -N "" -C "$node" -f "$hk" >/dev/null
    ok "generated (gitignored: node-${l}-extra/)."
  fi
  local recip; recip="$(ssh_to_age -i "${hk}.pub")"
  [[ "$recip" == age1* ]] || { err "ssh-to-age did not return an age recipient"; return; }
  note "${node} recipient: ${B}${recip}${R}"
  sops_add_node "$l" "$recip"
  ok "added ${node} recipient to .sops.yaml"

  # 2b. per-node Tailscale auth key (mint in the console, paste here)
  echo
  local do_key=1
  if encrypted "$tsfile"; then
    confirm "${node}-tailscale.sops.yaml exists — replace its auth key?" || do_key=0
  fi
  if (( do_key )); then
    local key; read -rsp "Paste ${node} tag:garage auth key (tskey-auth-…, hidden): " key || true; echo
    [[ "$key" == tskey-* ]] || warn "key does not start with tskey- — double-check it."
    umask 077; printf 'authkey: "%s"\n' "$key" > "$tsfile"
    sops --config "$SOPS_YAML" -e -i "$tsfile"
    if encrypted "$tsfile"; then ok "${node}-tailscale.sops.yaml encrypted."; else err "encryption failed"; return 1; fi
  else note "kept existing ${node} auth key."; fi

  # 2c. re-encrypt to the new recipient set
  note "re-encrypting secrets to include ${node}…"
  sops --config "$SOPS_YAML" updatekeys -y "$COMMON" >/dev/null
  [[ -f "$tsfile" ]] && sops --config "$SOPS_YAML" updatekeys -y "$tsfile" >/dev/null
  sops -d "$COMMON" >/dev/null && ok "decrypt check OK (workstation key)."

  echo
  ok "${node} workstation prep done."
  warn "MANUAL — before/at install (doc 13 §0.7 / Phase A|B):"
  cat <<EOF
   • Fill hosts/${node}.nix: networking.hostId (unique 8-hex), dataDirs capacities.
     node-b also: fleet.advertiseRoutes (the LAN CIDR it proxies).
   • Confirm disk device paths in hosts/disko-${node}.nix with \`lsblk\` ON THE BOX.
   • fleet.tailscaleIp is set AFTER first tailnet join (from \`tailscale status\`).
   • STAGE THE PAYLOAD onto your second USB stick:
       cp -r "${ROOT}"   /media/USB/garage-fleet
       # node-${l}-extra/ is gitignored — copy it explicitly (carries the host key):
       cp -r "${extra}"  /media/USB/garage-fleet/node-${l}-extra
EOF
  echo
  confirm "Print the on-box live-USB install guide for ${node} now?" && onbox_guide "$l"
}

# --- 3. manage age/sops secrets ---------------------------------------------
manage_secrets() {
  while :; do
    section "3. Secrets — manage the age-encrypted (sops) files"
    local files=(); shopt -s nullglob; files=("$SECRETS"/*.sops.yaml); shopt -u nullglob
    local f
    if ((${#files[@]})); then
      for f in "${files[@]}"; do printf '   '; encrypted "$f" && ok "$(basename "$f") (encrypted)" || err "$(basename "$f") PLAINTEXT!"; done
    else note "no secrets/*.sops.yaml yet (run 1 / 2)."; fi
    cat <<EOF

   e) edit a secret      (sops decrypts → \$EDITOR → re-encrypts in place)
   v) verify all encrypted + stage for commit (the pre-push safety gate)
   r) re-encrypt all     (sops updatekeys — after editing .sops.yaml recipients)
   s) open .sops.yaml in \$EDITOR (manage recipients by hand)
   b) back
EOF
    case "$(ask 'choice')" in
      e) ((${#files[@]})) || { warn "nothing to edit"; pause; continue; }
         local i=1; for f in "${files[@]}"; do printf '   %d) %s\n' "$i" "$(basename "$f")"; ((i++)); done
         local n; n="$(ask 'file #')"
         if [[ "$n" =~ ^[0-9]+$ ]] && (( n>=1 && n<=${#files[@]} )); then sops "${files[$((n-1))]}"; else warn "bad #"; fi;;
      v) echo; local bad; bad="$(grep -L '^sops:' "$SECRETS"/*.sops.yaml 2>/dev/null || true)"
         if [[ -n "$bad" ]]; then err "PLAINTEXT (do NOT commit):"; echo "$bad"
         else ok "all secrets/*.sops.yaml are encrypted."
           note "staging encrypted files + .sops.yaml for commit:"
           git -C "$ROOT" add .sops.yaml "$SECRETS"/*.sops.yaml 2>/dev/null || true
           git -C "$ROOT" status --short -- .sops.yaml secrets/ || true
           note "review, then: git commit -m 'fleet secrets' && git push"
         fi;;
      r) for f in "$SECRETS"/*.sops.yaml; do [[ -e "$f" ]] || continue; note "updatekeys $(basename "$f")"; sops --config "$SOPS_YAML" updatekeys -y "$f" >/dev/null; done; ok "re-encrypted to current recipients.";;
      s) "${EDITOR:-vi}" "$SOPS_YAML";;
      b|"") return;;
      *) warn "?";;
    esac
    pause
  done
}

# --- 4. validate flake -------------------------------------------------------
validate_flake() {
  section "4. Validate the flake"
  ( cd "$ROOT"
    note "nix flake lock"; nix flake lock || true
    note "nix flake check (needs step 1+2 done AND your SSH key in modules/base.nix)"
    if nix flake check 2>&1 | tail -20; then ok "flake check passed"
    else warn "flake check reported issues (above) — usually a missing SSH key / secret (Phase 0)"; fi
    echo
    local v; v="$(nix eval --raw .#nixosConfigurations.node-a.config.services.garage.package.version 2>/dev/null || echo '?')"
    note "garage package version on the pinned nixpkgs: ${B}${v}${R}"
    [[ "$v" == 2.3.* ]] || warn "design pins v2.3.0 but channel gives ${v} — bump the nixpkgs input (doc 13 §0)."
  )
}

# --- 5. on-box guide ---------------------------------------------------------
onbox_guide() {
  local l="${1:-}"
  [[ "$l" =~ ^[abcd]$ ]] || { l="$(ask 'On-box guide for which node? (a/b)')"; l="${l,,}"; }
  [[ "$l" =~ ^[ab]$ ]] || { warn "only a/b have a full guide here (c/d → doc 10)."; return; }
  local node="node-${l}" zone ver
  if [[ "$l" == a ]]; then zone="onsite"; ver=1; else zone="offsite-1"; ver=2; fi
  section "On-box live-USB install — ${node}  (zone ${zone})   [full: doc 13]"
  cat <<EOF
${B}On your WORKSTATION:${R} write the NixOS minimal USB, and a 2nd USB with the payload
  curl -L -o nixos.iso https://channels.nixos.org/nixos-25.05/latest-nixos-minimal-x86_64-linux.iso
  lsblk ; sudo dd if=nixos.iso of=/dev/sdX bs=4M conv=fsync status=progress     # sdX = the USB!
  # payload USB: cp -r ${ROOT} + node-${l}-extra/  (see step 2 output)

${B}Boot ${node} from the installer USB${R} (Lenovo: F12), then as root:
  sudo -i; ping -c1 nixos.org; lsblk            # CONFIRM disks vs hosts/disko-${node}.nix
  mkdir -p /mnt-usb && mount /dev/sdY1 /mnt-usb # payload USB
  cp -r /mnt-usb/garage-fleet /root/garage-fleet
  export NIX_CONFIG="experimental-features = nix-command flakes"
  cd /root/garage-fleet && { [ -f flake.lock ] || nix flake lock; }

${B}Format (DESTROYS both disks) — prompts for the ZFS passphrase TWICE${R} (same one,
write it offline now, never stored on the box):
  nix run github:nix-community/disko -- --mode destroy,format,mount --flake .#${node} --yes-wipe-all-disks

${B}Seed the SSH host key (matches your sops recipient) + install:${R}
  install -d -m700 /mnt/etc/ssh
  cp /mnt-usb/garage-fleet/node-${l}-extra/etc/ssh/ssh_host_ed25519_key{,.pub} /mnt/etc/ssh/
  chmod 600 /mnt/etc/ssh/ssh_host_ed25519_key; chmod 644 /mnt/etc/ssh/ssh_host_ed25519_key.pub
  nixos-install --flake /root/garage-fleet#${node} --no-root-passwd
  umount -R /mnt && zpool export -a && reboot   # pull the installer USB

${B}First boot:${R} set the REAL overlay IP, then unlock + start Garage:
  tailscale status                              # note ${node}'s 100.x.y.z
  # edit hosts/${node}.nix: fleet.tailscaleIp = "100.x.y.z"$([[ "$l" == b ]] && echo '  (+ fleet.advertiseRoutes)')
  sudo nixos-rebuild switch --flake /root/garage-fleet#${node}
  sudo zfs load-key -a && sudo zfs mount -a && sudo systemctl start garage
EOF
  if [[ "$l" == b ]]; then cat <<EOF

${B}Peer node-B into node-A's cluster (do this BEFORE node-B's layout):${R}
  # on node-A:  sudo garage node id -q            -> <pubkeyA>@100.x.y.A:3901
  # on node-B:  sudo garage node connect <pubkeyA>@100.x.y.A:3901
  #             sudo garage status                 # BOTH nodes HEALTHY
  # durable: set bootstrap_peers (both) in modules/garage.nix, then deploy-rs both.
EOF
  fi
  cat <<EOF

${B}Layout (zone ${zone}, version ${ver} — exactly prev+1, ONCE):${R}
  export GARAGE="sudo garage"; \$GARAGE status
  ID=\$(\$GARAGE node id -q | cut -d@ -f1)
  \$GARAGE layout assign "\$ID" -z ${zone} -c <bytes>      # size to backup set
  \$GARAGE layout show && \$GARAGE layout apply --version ${ver}
EOF
  [[ "$l" == b ]] && echo '  sudo garage repair -a --yes tables    # after the layout settles'
  cat <<EOF

${YEL}Reminder:${R} replication_factor=3 needs 3 zones. A (+B) is UNDER-REPLICATED until
node-C joins (doc 10 Phase 2). After ANY reboot, re-run:
  sudo zfs load-key -a && sudo zfs mount -a && sudo systemctl start garage
(prompt-unlock keeps a stolen offsite box locked — by design.)
EOF
}

# --- main menu ---------------------------------------------------------------
preflight
while :; do
  status
  cat <<EOF

  ${B}1${R}) Fleet secrets   — init/rotate the shared age-encrypted secrets (once)
  ${B}2${R}) Prepare node    — A/B/C/D: host key, recipient, tag:garage authkey, re-encrypt
  ${B}3${R}) Secrets         — list / edit / verify-encrypted / re-encrypt / stage to push
  ${B}4${R}) Validate        — nix flake lock + check + garage version
  ${B}5${R}) On-box guide    — print the live-USB install runbook for A or B
  ${B}q${R}) quit
EOF
  # `|| true`: these are interactive — a benign nonzero return (e.g. answering
  # "no" to a confirm) must return to the menu, not abort the script under set -e.
  case "$(ask 'choice')" in
    1) init_fleet_secrets || true; pause;;
    2) prepare_node || true; pause;;
    3) manage_secrets || true;;
    4) validate_flake || true; pause;;
    5) onbox_guide || true; pause;;
    q|Q|"") echo "bye."; exit 0;;
    *) warn "unknown choice";;
  esac
done
